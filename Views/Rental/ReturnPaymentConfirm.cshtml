@model rental.Models.Rental

@{
    Layout = "_Layout";

    // Controller’dan gelecek hesap
    var baseAmount = ViewBag.BaseAmount != null ? (decimal)ViewBag.BaseAmount : Model.Forecast;
    var penalty = ViewBag.Penalty != null ? (decimal)ViewBag.Penalty : 0;
    var total = ViewBag.Total != null ? (decimal)ViewBag.Total : Model.Forecast;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- HEADER -->
                <div class="card-header bg-danger text-white text-center py-4">
                    <h3 class="mb-0 fw-bold">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Ödeme Özeti
                    </h3>
                </div>

                <!-- BODY -->
                <div class="card-body p-4">

                    <div class="text-center mb-4">
                        <p class="text-muted">
                            Sayın kullanıcı,araç kiralama sürecine ait ödeme detayları aşağıdadır.
                        </p>
                    </div>

                    <!-- BİLGİLER -->
                    <div class="list-group list-group-flush border rounded-3 mb-4">

                        <div class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Planlanan İade Tarihi:</span>
                            <span class="fw-bold">@Model.ReturnDate.ToShortDateString()</span>
                        </div>

                        <div class="list-group-item d-flex justify-content-between bg-light">
                            <span class="text-muted">Ödeme Tarihi:</span>
                            <span class="fw-bold text-primary">@DateTime.Now.ToShortDateString()</span>
                        </div>

                        <div class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Kiralama Bedeli:</span>
                            <span class="fw-bold">@baseAmount.ToString("C2")</span>
                        </div>
@* 
                        @if (penalty > 0)
                        {
                            <div class="list-group-item d-flex justify-content-between text-danger">
                                <span>Gecikme Cezası (%3/gün):</span>
                                <span class="fw-bold">@penalty.ToString("C2")</span>
                            </div>
                        } *@

                    </div>


                    <!-- TOPLAM -->
                    <div class="text-center py-3">
                        <h4 class="text-muted mb-2">Toplam Ödenecek</h4>

                        <h1 class="display-4 fw-bold text-success">
                            @total.ToString("C2")
                        </h1>
                    </div>

                </div>

                <!-- FOOTER -->
                <div class="card-footer bg-white border-0 p-4 pt-0">

                    <div class="d-grid gap-2">

                        <!-- ÖDEME -->
                        <form asp-action="StartReturnPayment" asp-controller="Rental" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="rentalId" value="@Model.Id" />

                            <button type="submit" class="btn btn-success btn-lg rounded-pill shadow-sm w-100">

                                <i class="bi bi-credit-card"></i>
                                Ödemeyi Tamamla 
                            </button>

                        </form>

                        <!-- İPTAL -->
                        <a href="/User/MyRentals" class="btn btn-link text-decoration-none text-muted text-center">

                            İşlemi İptal Et
                        </a>

                    </div>

                </div>

            </div>

        </div>
    </div>
</div>