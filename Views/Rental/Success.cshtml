@model car.ViewModels.RentalSuccessViewModel
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body { background: #f8fafc; font-family: 'Segoe UI', sans-serif; }
    .success-card { border: none; border-radius: 25px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); overflow: hidden; }
    .status-icon { font-size: 80px; color: #22c55e; }
    .review-invite { background: #eff6ff; border: 1px dashed #3b82f6; border-radius: 20px; transition: 0.3s; }
    .review-invite:hover { background: #dbeafe; }
    #commentArea { display: none; transition: all 0.5s ease-in-out; }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 text-center">
            <div class="card success-card p-5 bg-white">
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill status-icon"></i>
                </div>
                <h1 class="fw-bold text-dark">Ödeme Başarılı!</h1>
                
                <hr class="my-4 opacity-25">
            @if (ViewBag.ShowReview == null || ViewBag.ShowReview == true)
            { <div class="review-invite p-4 mb-4" id="inviteBox">
                    <h5 class="fw-bold text-primary mb-2">Deneyiminizi değerlendirmek ister misiniz?</h5>
                    <p class="small text-secondary mb-3">Geri bildirimleriniz bizim için çok değerli.</p>
                    <div class="d-flex justify-content-center gap-3">
                        <button onclick="openCommentForm()" class="btn btn-primary rounded-pill px-4 fw-bold">Evet, İsterim</button>
                        <a href="/User/Index" class="btn btn-outline-secondary rounded-pill px-4">Daha Sonra</a>
                    </div>
                </div>

                <div id="commentArea" class="text-start p-4 bg-light rounded-4 border border-primary border-opacity-25 mb-4 style="display:none;">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">Yorumunuzu Yazın</h5>
                    <form asp-controller="Car" asp-action="AddComment" method="post">
                        @Html.AntiForgeryToken()
                        @* Kiralama bilgisinden CarId'yi çekiyoruz *@
                        <input type="hidden" name="carId" value="@Model.CarId" />
                        
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Puan Verin</label>
                            <select name="rating" class="form-select rounded-3 border-primary border-opacity-50">
                                <option value="5">⭐⭐⭐⭐⭐ - Mükemmel</option>
                                <option value="4">⭐⭐⭐⭐ - Çok İyi</option>
                                <option value="3">⭐⭐⭐ - Orta</option>
                                <option value="2">⭐⭐ - Kötü</option>
                                <option value="1">⭐ - Çok Kötü</option>
                            </select>
                        </div>
                
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Yorumunuz</label>
                            <textarea name="comment" class="form-control rounded-3" rows="3" placeholder="Araç durumu, teslimat süreci nasıldı?" required></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success flex-fill rounded-pill fw-bold">Değerlendirmeyi Gönder</button>
                            <button type="button" onclick="closeCommentForm()" class="btn btn-light rounded-pill px-3">İptal</button>
                        </div>
                    </form>
                </div>
            }
                <div class="d-grid gap-2">
                    <a href="/User/MyRentals" class="btn btn-dark btn-lg rounded-pill fw-bold">Kiralamalarımı Görüntüle</a>
                    <a href="/User/Index" class="btn btn-link text-decoration-none text-muted">Ana Sayfaya Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCommentForm() {
            // Davet kutusunu gizle, form alanını aç
            document.getElementById("inviteBox").style.display = "none";
            document.getElementById("commentArea").style.display = "block";
        }

        function closeCommentForm() {
            // Formu gizle, davet kutusunu geri getir
            document.getElementById("inviteBox").style.display = "block";
            document.getElementById("commentArea").style.display = "none";
        }
    </script>
}