@model rental.Models.Rental
@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-center">Kart İle Ödeme</h5>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger small">@TempData["ErrorMessage"]</div>
                    }

                    <form asp-controller="Rental" asp-action="CompletePayment" method="post">
                        @* 🚩 KRİTİK: Model verilerini gizli input olarak taşıyoruz *@
                        <input type="hidden" name="CarId" value="@Model?.CarId" />
                        <input type="hidden" name="Date" value="@Model?.Date.ToString("yyyy-MM-dd HH:mm")" />
                        <input type="hidden" name="ReturnDate"
                               value="@Model?.ReturnDate.ToString("yyyy-MM-dd HH:mm")" />
                        <input type="hidden" name="Forecast" value="@Model?.Forecast.ToString().Replace(",", ".")" />
                        
                        <div class="mb-3">
                            <input type="text" name="CardHolderName" class="form-control" placeholder="Kart Sahibi Adı"
                                   required />
                        </div>
                        <div class="mb-3">
                            <input type="text" name="CardNumber" class="form-control" placeholder="Kart Numarası"
                                   required />
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <input type="text" name="ExpireMonth" class="form-control" placeholder="AY (MM)"
                                       required />
                            </div>
                            <div class="col-6 mb-3">
                                <input type="text" name="ExpireYear" class="form-control" placeholder="YIL (YYYY)"
                                       required />
                            </div>
                        </div>
                        <div class="mb-4">
                            <input type="text" name="Cvc" class="form-control" placeholder="CVC" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill">
                            @(Model?.Forecast.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))) TL ÖDE
                        </button>
                        
                    </form>
                    
                    <div class="text-center mt-3">
                        <img src="https://www.iyzico.com/assets/images/logo.svg" width="80" alt="iyzico">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>