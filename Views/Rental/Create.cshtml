@using car.Models
@model rental.Models.Rental
@{
    // 'as' kullanmak yerine dinamik çekelim, böylece tip uyuşmazlığı olsa da veriyi okur.
    dynamic car = ViewBag.Car;
    Layout = "_Layout";
}

@if (car == null)
{
    <div class="alert alert-danger">
        <strong>🚩 Durum:</strong> Veri çantası (ViewBag.Car) boş! <br />
        <strong>Çözüm:</strong> RentalController içindeki <code>ViewBag.Car = car;</code> satırının çalıştığından emin olun.
    </div>
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white text-center py-3">
            <h4 class="mb-0">🚗 Kiralama Talebi: @car?.Brand @car?.ModelName</h4>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-5 text-center border-end">
                    <img src="@car?.ImagePath" class="img-fluid rounded shadow-sm mb-3"
                         style="max-height: 250px; width: 100%; object-fit: cover;">
                    <div class="alert alert-dark fw-bold">Plaka: @car?.Plate</div>
                </div>
                
                <div class="col-md-7">
                    <form asp-controller="Rental" asp-action="StartPayment" method="post">
                        <input type="hidden" name="CarId" value="@car?.Id" id="carIdField" />
                        
                        <input type="hidden" id="hiddenForecast" name="Forecast" value="0" />
                        <input type="hidden" id="hiddenDeposit" name="Deposit" value="0" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Alış Tarihi</label>
                            <input type="text" id="startDate" name="Date" class="form-control bg-white"
                                   placeholder="Tarih Seçiniz..." required>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">İade Tarihi</label>
                            <input type="text" id="endDate" name="ReturnDate" class="form-control bg-white"
                                   placeholder="Tarih Seçiniz..." required>
                        </div>

                        <div id="priceSummary" class="card bg-light mb-4 d-none border-primary">
                            <div class="card-body">
                                <p class="mb-1">Süre: <span id="daysCount" class="fw-bold text-dark">0</span> Gün</p>
                                <p class="mb-1">Toplam: <strong id="totalPrice" class="text-primary">0</strong> TL</p>
                                <p class="mb-0 text-danger">Ödenecek Depozito (%10): <strong
                                    id="depositAmount">0</strong> TL</p>
                                </div>
                            </div>

                            <button type="submit" id="submitBtn" class="btn btn-primary w-100 py-3 fw-bold shadow">
                                <i class="bi bi-credit-card"></i> Depozito Öde ve Devam Et
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            // Controller'dan gelen dolu tarihleri alıyoruz
            const disabledDates = @Html.Raw(ViewBag.DisabledDates ?? "[]");
            const carId = document.getElementById('carIdField').value;

            // Flatpickr Ayarları (Dolu tarihler seçilemez)
            const commonConfig = {
            minDate: "today",
            disable: disabledDates,
            dateFormat: "Y-m-d",
            locale: { firstDayOfWeek: 1 }
            };

            const startPicker = flatpickr("#startDate", {
            ...commonConfig,
            onChange: function (selectedDates) {
            endPicker.set("minDate", selectedDates[0] ? selectedDates[0] : "today");
            updatePrice();
            }
            });

            const endPicker = flatpickr("#endDate", {
            ...commonConfig,
            onChange: function () {
            updatePrice();
            }
            });

            function updatePrice() {
            const startStr = document.getElementById('startDate').value;
            const endStr = document.getElementById('endDate').value;

            if (startStr && endStr) {
            const start = new Date(startStr);
            const end = new Date(endStr);
                
            if (end > start) {
            const days = Math.ceil(Math.abs(end - start) / (1000 * 60 * 60 * 24));
                    
            // Fiyatı getir
            fetch(`/Rental/GetPriceCalculation?carId=${carId}&days=${days}`)
            .then(r => r.json())
            .then(data => {
            // Veri 0 geliyorsa veya null geliyorsa kontrol ediyoruz
            const total = data.total || 0;
            const deposit = data.deposit || 0;

            document.getElementById('priceSummary').classList.remove('d-none');
            document.getElementById('daysCount').innerText = days;
            document.getElementById('totalPrice').innerText = total.toLocaleString('tr-TR');
            document.getElementById('depositAmount').innerText = deposit.toLocaleString('tr-TR');
                            
            // Inputları doldur
            document.getElementById('hiddenForecast').value = total;
            document.getElementById('hiddenDeposit').value = deposit;
            })
            .catch(err => console.error("Fiyat çekilirken hata oluştu:", err));
            }
            }
            }
        </script>
    }