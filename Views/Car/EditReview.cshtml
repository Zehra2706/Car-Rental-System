@model car.Models.Review
@{
    Layout = "_Layout";
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Değerli Üyemiz");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body { margin: 0; font-family: 'Segoe UI', sans-serif; background: #f4f7fa; padding-top: 80px; }

    /* TOPBAR */
    .custom-topbar {
        position: fixed; top: 0; left: 0; right: 0; height: 70px;
        background: white; display: flex; align-items: center;
        justify-content: space-between; padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08); z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }

    /* SIDEBAR */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #1e3a8a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.15); color: white; }

    /* FORM CARD */
    .edit-card {
        border: none; border-radius: 20px; background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area d-flex align-items-center gap-3">
        <a href="/Car/MyReviews" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            <i class="bi bi-arrow-left me-1"></i> Geri Dön
        </a>
        <span class="fw-bold text-dark d-none d-md-inline">
            <i class="bi bi-person-circle me-1 text-primary"></i> @displayDisplayName
        </span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/User/Index"><i class="bi bi-house-door me-2"></i> Dashboard</a>
    <a href="/User/AvailableCars"><i class="bi bi-car-front me-2"></i> Araç Kirala</a>
    <a href="/User/MyRentals"><i class="bi bi-list-check me-2"></i> Kiralamalarım</a>
    <hr class="opacity-25">
    <a href="/Car/MyReviews"><i class="bi bi-chat-left-text me-2"></i> Yorumlarım</a>
    <a href="/Car/MyCars"><i class="bi bi-tags me-2"></i> İlanlarım</a>
    <a href="/User/EditProfile"><i class="bi bi-gear me-2"></i> Ayarlar</a>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="mb-4">
                <h2 class="fw-bold text-dark m-0"><i class="bi bi-pencil-square text-primary"></i> Değerlendirmeyi Güncelle</h2>
                <p class="text-muted small">Yorumunuzu ve puanınızı buradan revize edebilirsiniz.</p>
            </div>

            <div class="card edit-card p-5">
                <form asp-action="EditReview" method="post">
                    @* Gizli ID Alanları *@
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="CarId" value="@Model.CarId" />

                   

                    <div class="mb-4">
                        <label class="form-label fw-bold small">Puanınız</label>
                        <select name="rating" class="form-select rounded-3 shadow-sm border-primary border-opacity-25">
                            <option value="5" selected="@(Model.Rating == 5)">⭐⭐⭐⭐⭐ - Mükemmel</option>
                            <option value="4" selected="@(Model.Rating == 4)">⭐⭐⭐⭐ - Çok İyi</option>
                            <option value="3" selected="@(Model.Rating == 3)">⭐⭐⭐ - Orta</option>
                            <option value="2" selected="@(Model.Rating == 2)">⭐⭐ - Kötü</option>
                            <option value="1" selected="@(Model.Rating == 1)">⭐ - Çok Kötü</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small">Yorumunuz</label>
                        <textarea name="comment" class="form-control rounded-3 shadow-sm" rows="5" required placeholder="Araç hakkındaki düşünceleriniz...">@Model.Comment</textarea>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg shadow rounded-pill py-3 fw-bold">
                            <i class="bi bi-save2-fill me-2"></i> Değişiklikleri Kaydet
                        </button>
                        <a href="/Car/MyReviews" class="btn btn-link text-decoration-none text-muted">Vazgeç ve Listeye Dön</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }
</script>