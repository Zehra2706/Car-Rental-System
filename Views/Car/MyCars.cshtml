@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}
@model List<car.Models.Car>
@{
    Layout = "_Layout";
    // Kullanıcı adını diğer sayfalarla aynı mantıkta çekiyoruz
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Değerli Üyemiz");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 80px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }
    .topbar-right-area { display: flex; align-items: center; gap: 20px; }
    .logout-btn-new {
        background: #ef4444; color: white; border: none;
        padding: 8px 16px; border-radius: 10px; font-weight: 600; text-decoration: none;
    }

    /* SIDEBAR */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #1e3a8a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.15); color: white; }

    /* İLAN KARTLARI */
    .my-car-card {
        transition: all 0.3s ease;
        border-radius: 20px;
        background: white;
        border: none;
    }
    .my-car-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area">
        <span class="fw-bold text-dark d-none d-md-inline">
            <i class="bi bi-person-circle me-1 text-primary"></i> @displayDisplayName
        </span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/User/Index"><i class="bi bi-house-door me-2"></i> Dashboard</a>
    <a href="/User/AvailableCars"><i class="bi bi-car-front me-2"></i> Araç Kirala</a>
    <a href="/User/MyRentals"><i class="bi bi-list-check me-2"></i> Kiralamalarım</a>
    <hr class="opacity-25">
    <a href="/User/IncomingRequests?filter=aktif"><i class="bi bi-bell-fill me-2 text-warning"></i> Talepleri Yönet</a>
    <a href="/Car/MyCars"><i class="bi bi-tags me-2"></i> İlanlarım</a>
    <a href="/Car/Create"><i class="bi bi-plus-square me-2"></i> Araç Ekle</a>
    <a href="/User/EditProfile"><i class="bi bi-gear me-2"></i> Ayarlar</a>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="bi bi-tags-fill text-primary"></i> İlanlarımı Yönet</h2>
            <p class="text-muted small">Paylaştığın tüm araçları buradan güncelleyebilir veya silebilirsin.</p>
        </div>
        <div class="d-flex gap-2">
        <!-- GERİ DÖN BUTONU -->
        <a href="/User/Index" class="btn btn-outline-dark rounded-pill px-4 fw-bold shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Geri Dön
        </a>

        <!-- YENİ İLAN -->
        <a href="/Car/create" class="btn btn-success shadow-sm rounded-pill px-4 fw-bold">
            <i class="bi bi-plus-lg me-2"></i>Yeni İlan Ekle
        </a>
    </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var car in Model)
        {
            <div class="col">
                <div class="card h-100 my-car-card shadow-sm overflow-hidden">
                    <div style="height: 200px; overflow: hidden; position: relative;">
                        <img src="@(string.IsNullOrEmpty(car.ImagePath) ? "/images/no-image.png" : car.ImagePath)"
                             class="card-img-top h-100 w-100" style="object-fit: cover;" alt="@car.Brand">
                        <span class="badge bg-primary position-absolute top-0 end-0 m-3 shadow-sm px-3 py-2 rounded-pill">@car.ModelYear</span>
                    </div>

                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold text-uppercase mb-2">@car.Brand @car.ModelName</h5>
                        <p class="card-text text-muted small mb-3">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i> @car.Location
                        </p>
                        
                        <div class="p-3 rounded-4 bg-light mb-3 border border-opacity-10 border-primary">
                            @if (car.Prices != null && car.Prices.Any())
                            {
                                var p = car.Prices.First();
                                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                                    <small class="fw-bold text-secondary">Günlük:</small>
                                    <span class="text-primary fw-bold">@p.daily.ToString("C2")</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center small">
                                    <small class="text-muted">Aylık:</small>
                                    <span class="text-dark fw-semibold">@p.monthly.ToString("C2")</span>
                                </div>
                            }
                            else
                            {
                                <div class="text-center"><span class="text-muted small italic">Fiyat Belirtilmedi</span></div>
                            }
                        </div>

                        <p class="card-text text-muted small mb-0 text-truncate">@car.Description</p>
                    </div>

                    <div class="card-footer bg-white border-0 d-flex gap-2 p-4 pt-0">
                        <a href="/Car/Edit/@car.Id" class="btn btn-outline-primary rounded-pill btn-sm flex-fill fw-bold">
                            <i class="bi bi-pencil-square me-1"></i> Düzenle
                        </a>
                        <form method="post" action="/Car/Delete" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@car.Id" />

                            <button type="submit"
                                    class="btn btn-outline-danger rounded-pill btn-sm flex-fill fw-bold"
                                    onclick="return confirm('Bu ilanı silmek istediğine emin misin?')">
                                <i class="bi bi-trash3 me-1"></i> Sil
                            </button>
                        </form>
                        <a href="/Car/ToggleActive/@car.Id"
                            class="btn btn-sm @(car.IsActive ? "btn-warning" : "btn-success") rounded-pill flex-fill fw-bold">
                            <i class="bi @(car.IsActive ? "bi-eye-slash" : "bi-eye") me-1"></i>
                            @(car.IsActive ? "İlanı Kapat" : "İlanı Aç")
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-car-front display-1 text-muted opacity-25"></i>
            <h4 class="mt-4 text-secondary">Henüz bir ilan paylaşmamışsın.</h4>
            <a href="/Car/Create" class="btn btn-primary mt-3 rounded-pill px-5">İlk İlanını Hemen Oluştur</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function toggleMenu() {
            document.getElementById("sidebar").classList.toggle("active");
        }

        function confirmDelete(id) {
            if (confirm("Bu ilanı tamamen silmek istediğinize emin misiniz?")) {
            }
        }
    </script>
}