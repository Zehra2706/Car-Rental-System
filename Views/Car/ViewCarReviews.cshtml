@model List<car.Models.Review>
@{
    Layout = "_Layout";
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Değerli Üyemiz");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body { margin: 0; font-family: 'Segoe UI', sans-serif; background: #f4f7fa; padding-top: 85px; }

    /* TOPBAR */
    .custom-topbar {
        position: fixed; top: 0; left: 0; right: 0; height: 70px;
        background: white; display: flex; align-items: center;
        justify-content: space-between; padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08); z-index: 2000;
    }
    .topbar-left-btn { font-size: 28px; cursor: pointer; color: #1e3a8a; }

    /* SIDEBAR */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #1e3a8a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.15); color: white; }

    /* YORUM KARTLARI */
    .review-item-card {
        border: none; border-radius: 20px; background: white;
        transition: 0.3s; border-left: 6px solid #1e3a8a;
    }
    .review-item-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important; }
    .rating-stars { color: #f59e0b; }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="d-flex align-items-center gap-3">
<a href="/Rental/Create?carId=@ViewBag.CarId" class="btn btn-primary rounded-pill">
    <i class="bi bi-arrow-left"></i> Araç Detayına Dön
</a>
        <span class="fw-bold text-dark d-none d-md-inline border-start ps-3">
            <i class="bi bi-person-circle text-primary me-1"></i> @displayDisplayName
        </span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/User/Index"><i class="bi bi-house-door me-2"></i> Dashboard</a>
    <a href="/User/AvailableCars"><i class="bi bi-car-front me-2"></i> Araç Kirala</a>
    <a href="/User/MyRentals"><i class="bi bi-list-check me-2"></i> Kiralamalarım</a>
    <hr class="opacity-25">
    <a href="/Car/MyReviews"><i class="bi bi-chat-left-text me-2"></i> Yorumlarım</a>
    <a href="/Car/MyCars"><i class="bi bi-tags me-2"></i> İlanlarım</a>
    <a href="/Auth/Logout" class="text-danger mt-5"><i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap</a>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="text-center mb-5">
                <h2 class="fw-bold text-dark mb-1">@ViewBag.CarInfo</h2>
                <h5 class="text-primary opacity-75">Kullanıcı Değerlendirmeleri</h5>
                <p class="text-muted small">Toplam @(Model?.Count ?? 0) yorum bulundu.</p>
            </div>

            @if (Model != null && Model.Any())
            {
                @foreach (var review in Model)
                {
                    <div class="card review-item-card shadow-sm p-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="rating-stars fs-5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star text-muted")"></i>
                                }
                                <span class="ms-2 text-dark fw-bold small">@review.Rating / 5</span>
                            </div>
                            <span class="badge bg-light text-secondary rounded-pill px-3">
                                <i class="bi bi-calendar3 me-1"></i> @review.CreatedDate.ToString("dd.MM.yyyy")
                            </span>
                        </div>
                        
                        <p class="fs-5 text-dark mb-0" style="font-style: italic; color: #444 !important;">
                            "@review.Comment"
                        </p>

                        <div class="mt-4 pt-3 border-top d-flex align-items-center justify-content-between">
                            <span class="small text-muted"><i class="bi bi-patch-check-fill text-success me-1"></i> Doğrulanmış Müşteri</span>
                            <span class="small text-muted">ID: #@review.Id</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 bg-white rounded-5 shadow-sm border border-dashed">
                    <i class="bi bi-chat-quote display-1 text-muted opacity-25"></i>
                    <h3 class="mt-3 text-secondary fw-bold">Henüz Yorum Yok</h3>
                    <p class="text-muted">Bu araç henüz değerlendirilmemiş. İlk kiralayan sen olabilirsin!</p>
                   <a href="/Rental/Create?carId=@ViewBag.CarId" class="btn btn-primary rounded-pill px-5 py-3 fw-bold">
    Aracı İncele ve Kirala
</a>         </div>
            }
        </div>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }
</script>