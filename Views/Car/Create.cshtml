<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <form action="/Car/Create" method="post" enctype="multipart/form-data">
                <div class="card p-4 shadow-sm border-0 rounded-4">
                    <h4 class="mb-4 text-primary fw-bold">
                        <i class="bi bi-car-front-fill"></i> Yeni Araç Tanımlama
                    </h4>

                    @* Marka & Model *@
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Marka</label>
                            <input type="text" name="Brand" placeholder="Örn: BMW" class="form-control shadow-sm"
                                   required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Model</label>
                            <input type="text" name="ModelName" placeholder="Örn: 3.20i" class="form-control shadow-sm"
                                   required>
                        </div>
                    </div>

                    @* Araç Detayları *@
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Model Yılı</label>
                            <input type="number" name="ModelYear" class="form-control shadow-sm" placeholder="2024"
                                   required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Renk</label>
                            <input type="text" name="Color" class="form-control shadow-sm" placeholder="Beyaz" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Konum (Şehir)</label>
                            <input type="text" name="Location" class="form-control shadow-sm" placeholder="Ankara"
                                   required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold text-danger">Araç Plakası</label>
                            <input type="text" name="Plate"
                                   class="form-control shadow-sm border-danger border-opacity-25" placeholder="34 ABC 123"
                                   required>
                        </div>
                    </div>

                    @* Fotoğraf *@
                    <div class="mb-4">
                        <label class="form-label fw-bold text-success">Araç Fotoğrafı</label>
                        <input type="file" name="ImageFile" class="form-control shadow-sm" accept="image/*" required>
                    </div>

                    @* Kiralama Ücretleri *@
                    <div class="p-4 mb-4 bg-light rounded-4 border border-success border-opacity-25 shadow-sm">
                        <h6 class="text-success mb-3 fw-bold"><i class="bi bi-currency-exchange"></i> Kiralama Ücretleri
                            (₺)</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Günlük</label>
                                    <input type="number" step="0.01" name="DailyPrice" class="form-control"
                                           placeholder="0.00" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Haftalık</label>
                                    <input type="number" step="0.01" name="WeeklyPrice" class="form-control"
                                           placeholder="0.00" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Aylık</label>
                                    <input type="number" step="0.01" name="MonthlyPrice" class="form-control"
                                           placeholder="0.00" required>
                                </div>
                            </div>
                        </div>

                        @* Teknik Bilgiler *@
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Vites Tipi</label>
                                <select name="Transmission" class="form-select shadow-sm">
                                    <option value="0">Automatic</option>
                                    <option value="1">Manual</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Yakıt Tipi</label>
                                <select name="FuelType" class="form-select shadow-sm">
                                    <option value="0">Gasoline</option>
                                    <option value="1">Diesel</option>
                                    <option value="2">Electric</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Motor Hacmi (L)</label>
                                <input type="number" step="0.1" name="EngineSize" class="form-control shadow-sm"
                                       placeholder="1.6" required>
                            </div>
                        </div>

                        @* 🚩 SİGORTA BÖLÜMÜ (SADECE EVET VE UYARI) *@
                        <div class="p-4 mb-4 border rounded-4 bg-white shadow-sm border-primary">
                            <h6 class="fw-bold text-dark mb-3"><i class="bi bi-shield-check text-primary"></i> Sigorta Onayı
                            </h6>
                        
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="IsInsured" id="isInsuredCheck"
                                       value="true" required checked>
                                <label class="form-check-label fw-bold text-success" for="isInsuredCheck">
                                    Aracın sigortası/kaskosu mevcuttur.
                                </label>
                            </div>
                            <p class="text-danger small fw-bold mb-3">
                                <i class="bi bi-exclamation-triangle-fill"></i> Sigortasız araç kabul edilmemekte.
                            </p>

                            <div id="insuranceNoArea">
                                <label class="form-label small fw-bold text-muted">SİGORTA POLİÇE NUMARASI <span
                                    class="text-danger">*</span></label>
                                    <input type="text" name="MotorInsurance" class="form-control border-primary"
                                           placeholder="Poliçe numarasını giriniz" required>
                                </div>
                            </div>

                            @* Açıklama *@
                            <div class="mb-4">
                                <label class="form-label fw-bold">Araç Açıklaması</label>
                                <textarea name="Description" class="form-control shadow-sm" rows="3"
                                          placeholder="Aracın durumu hakkında detaylı bilgi verin..." required></textarea>
                            </div>

                          

                            @* Kaydet Butonu *@
                            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm rounded-pill py-3 fw-bold">
                                <i class="bi bi-cloud-arrow-up-fill"></i> Aracı Sisteme Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>