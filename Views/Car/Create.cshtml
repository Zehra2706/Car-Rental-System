@{
    Layout = "_Layout";
    // Kullanıcı adını diğer sayfalarla aynı mantıkta çekiyoruz
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Değerli Üyemiz");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 90px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }
    .topbar-right-area { display: flex; align-items: center; gap: 20px; }
    .logout-btn-new {
        background: #ef4444; color: white; border: none;
        padding: 8px 16px; border-radius: 10px; font-weight: 600; text-decoration: none;
    }

    /* SIDEBAR */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #1e3a8a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.15); color: white; }

    /* FORM CARD */
    .form-card {
        border: none;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .form-label { font-size: 0.9rem; color: #475569; }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area">
        <span class="fw-bold text-dark d-none d-md-inline">
            <i class="bi bi-person-circle me-1 text-primary"></i> @displayDisplayName
        </span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/User/Index"><i class="bi bi-house-door me-2"></i> Ana Sayfa</a>
    <a href="/User/AvailableCars"><i class="bi bi-car-front me-2"></i> Araç Kirala</a>
    <a href="/User/MyRentals"><i class="bi bi-list-check me-2"></i> Kiralamalarım</a>
    <hr class="opacity-25">
    <a href="/User/IncomingRequests?filter=aktif"><i class="bi bi-bell-fill me-2 text-warning"></i> Talepleri Yönet</a>
    <a href="/Car/MyCars"><i class="bi bi-tags me-2"></i> İlanlarım</a>
    <a href="/Car/Create"><i class="bi bi-plus-square me-2"></i> Araç Ekle</a>
    <a href="/User/EditProfile"><i class="bi bi-gear me-2"></i> Ayarlar</a>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-dark m-0">🚗 Yeni Araç Tanımla</h2>
                <a href="/User/Index" class="btn btn-white shadow-sm rounded-pill border-0 px-4">
                    <i class="bi bi-arrow-left"></i> Vazgeç
                </a>
            </div>

            <form action="/Car/Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
                <div class="form-card card p-5">
                    <h4 class="mb-4 text-primary fw-bold border-bottom pb-3">
                        <i class="bi bi-info-circle-fill me-2"></i>Araç Temel Bilgileri
                    </h4>

                    @* Marka & Model *@
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Marka</label>
                            <input type="text" name="Brand" placeholder="Örn: BMW" class="form-control rounded-3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Model</label>
                            <input type="text" name="ModelName" placeholder="Örn: 3.20i" class="form-control rounded-3" required>
                        </div>
                    </div>

                    @* Araç Detayları *@
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Model Yılı</label>
                            <input type="number" name="ModelYear" class="form-control rounded-3" placeholder="2024" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Renk</label>
                            <input type="text" name="Color" class="form-control rounded-3" placeholder="Beyaz" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Konum (Şehir)</label>
                            <input type="text" name="Location" class="form-control rounded-3" placeholder="Ankara" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold text-danger">Araç Plakası</label>
                            <input type="text" name="Plate" class="form-control rounded-3 border-danger border-opacity-25" placeholder="34 ABC 123" required>
                        </div>
                    </div>

                    @* Fotoğraf *@
                    <div class="mb-4">
                        <label class="form-label fw-bold text-success">Araç Fotoğrafı</label>
                        <input type="file" name="ImageFile" class="form-control rounded-3 shadow-sm" accept="image/*" required>
                    </div>

                    @* Kiralama Ücretleri *@
                    <div class="p-4 mb-4 bg-light rounded-4 border border-success border-opacity-25 shadow-sm">
                        <h6 class="text-success mb-3 fw-bold"><i class="bi bi-currency-exchange me-2"></i>Kiralama Ücretleri (₺)</h6>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Günlük Ücret</label>
                                <input type="number" step="0.01" name="DailyPrice" class="form-control rounded-3" placeholder="0.00" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Haftalık Ücret</label>
                                <input type="number" step="0.01" name="WeeklyPrice" class="form-control rounded-3" placeholder="0.00" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Aylık Ücret</label>
                                <input type="number" step="0.01" name="MonthlyPrice" class="form-control rounded-3" placeholder="0.00" required>
                            </div>
                        </div>
                    </div>

                    @* Teknik Bilgiler *@
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Vites Tipi</label>
                            <select name="Transmission" class="form-select rounded-3">
                                <option value="0">Otomatik</option>
                                <option value="1">Manuel</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Yakıt Tipi</label>
                            <select name="FuelType" class="form-select rounded-3">
                                <option value="0">Benzin</option>
                                <option value="1">Dizel</option>
                                <option value="2">Elektrik</option>
                                <option value="3">Hibrit</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Motor Hacmi</label>
                            <input type="number" step="0.1" name="EnginePower" class="form-control rounded-3" placeholder="1,6" required>
                        </div>
                    </div>

                    @* Sigorta Bölümü *@
                    <div class="p-4 mb-4 border rounded-4 bg-white shadow-sm border-primary">
                        <h6 class="fw-bold text-dark mb-3"><i class="bi bi-shield-check text-primary me-2"></i>Sigorta / Kasko Onayı</h6>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="IsInsured" id="isInsuredCheck" value="true" required checked>
                            <label class="form-check-label fw-bold text-success" for="isInsuredCheck">
                                Aracın sigortası/kaskosu mevcuttur.
                            </label>
                        </div>
                        <p class="text-danger small fw-bold mb-3">
                            <i class="bi bi-exclamation-triangle-fill"></i> Güvenlik protokolü gereği sigortasız araç kabul edilmemektedir.
                        </p>
                        <div id="insuranceNoArea">
                            <label class="form-label small fw-bold text-muted">SİGORTA POLİÇE NUMARASI <span class="text-danger">*</span></label>
                            <input type="text" name="MotorInsurance" class="form-control border-primary rounded-3" placeholder="Örn: POL-12345678" required>
                        </div>
                    </div>

                    @* Açıklama *@
                    <div class="mb-4">
                        <label class="form-label fw-bold">Araç Açıklaması</label>
                        <textarea name="Description" class="form-control rounded-3" rows="3" placeholder="Aracın durumu, özellikleri ve kiralama şartları hakkında detaylı bilgi verin..." required></textarea>
                    </div>

                    @* Kaydet Butonu *@
                    <button type="submit" class="btn btn-primary btn-lg w-100 shadow rounded-pill py-3 fw-bold">
                        <i class="bi bi-cloud-arrow-up-fill me-2"></i> Aracı Sisteme Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }
</script>