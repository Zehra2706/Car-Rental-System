@model List<car.Models.Review>
@{
    Layout = "_Layout";
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Değerli Üyemiz");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body { margin: 0; font-family: 'Segoe UI', sans-serif; background: #f4f7fa; padding-top: 80px; }

    /* TOPBAR */
    .custom-topbar {
        position: fixed; top: 0; left: 0; right: 0; height: 70px;
        background: white; display: flex; align-items: center;
        justify-content: space-between; padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08); z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }

    /* SIDEBAR */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #1e3a8a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.15); color: white; }
    .sidebar .active-link { background: rgba(255,255,255,0.2); color: white; font-weight: bold; }

    /* KART TASARIMI */
    .review-card {
        border: none; border-radius: 20px; transition: 0.3s; background: white;
    }
    .review-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important; }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area d-flex align-items-center gap-3">
        <a href="/User/Index" class="btn btn-outline-primary btn-sm rounded-pill px-3">
            <i class="bi bi-house-door me-1"></i> Ana Sayfaya Dön
        </a>
        <span class="fw-bold text-dark d-none d-md-inline">
            <i class="bi bi-person-circle me-1 text-primary"></i> @displayDisplayName
        </span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/User/Index"><i class="bi bi-house-door me-2"></i> Dashboard</a>
    <a href="/User/AvailableCars"><i class="bi bi-car-front me-2"></i> Araç Kirala</a>
    <a href="/User/MyRentals"><i class="bi bi-list-check me-2"></i> Kiralamalarım</a>
    <hr class="opacity-25">
    <a href="/Car/MyReviews" class="active-link"><i class="bi bi-chat-left-text me-2"></i> Yorumlarım</a>
    <a href="/Car/MyCars"><i class="bi bi-tags me-2"></i> İlanlarım</a>
    <a href="/User/EditProfile"><i class="bi bi-gear me-2"></i> Ayarlar</a>
    <a href="/Auth/Logout" class="text-danger mt-5"><i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap</a>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="bi bi-chat-square-quote-fill text-primary"></i> Yorumlarımı Yönet</h2>
            <p class="text-muted small">Yaptığın tüm değerlendirmeleri buradan görebilir ve düzenleyebilirsin.</p>
        </div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var review in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card review-card shadow-sm p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="fw-bold text-primary mb-1">@review.Car?.Brand @review.Car?.ModelName</h5>
                            <span class="badge bg-warning text-dark rounded-pill">@review.Rating ⭐</span>
                        </div>
                        <p class="text-muted x-small mb-3">@review.CreatedDate.ToString("dd.MM.yyyy HH:mm")</p>
                        <p class="text-dark">"@review.Comment"</p>
                        
                        <div class="d-flex gap-2 pt-3 border-top mt-2">
                            <a href="/Car/EditReview/@review.Id" class="btn btn-outline-primary btn-sm rounded-pill flex-fill">
                                <i class="bi bi-pencil me-1"></i> Düzenle
                            </a>
                            <button onclick="confirmDelete(@review.Id)" class="btn btn-outline-danger btn-sm rounded-pill flex-fill">
    <i class="bi bi-trash3 me-1"></i> Sil
</button>
                           
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-chat-left-dots display-1 text-muted opacity-25"></i>
                <h4 class="mt-3 text-secondary">Henüz yorumun yok.</h4>
                <a href="/User/Index" class="btn btn-primary rounded-pill px-4 mt-2">Ana Sayfaya Git</a>
            </div>
        }
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }

    function confirmDelete(id) {
        if (confirm("Bu yorumu silmek istediğine emin misin?")) {
            window.location.href = "/Car/DeleteReview/" + id;
        }
    }
    function confirmDelete(id) {
        if (confirm("Bu yorumu silmek istediğine emin misin?")) {
            // Controller'daki metodun adı ve ID gidiyor
            window.location.href = "/Car/DeleteReview/" + id;
        }
    }
</script>