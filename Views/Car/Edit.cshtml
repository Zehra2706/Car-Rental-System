@model car.ViewModels.CarCreateViewModel

@{
    Layout = "_Layout";
    // Kullanıcı adını diğer sayfalarla aynı mantıkta çekiyoruz
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Değerli Üyemiz");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 90px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }
    .topbar-right-area { display: flex; align-items: center; gap: 20px; }
    .logout-btn-new {
        background: #ef4444; color: white; border: none;
        padding: 8px 16px; border-radius: 10px; font-weight: 600; text-decoration: none;
    }

    /* SIDEBAR */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #1e3a8a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.15); color: white; }

    /* FORM CARD */
    .edit-card {
        border: none;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area">
        <span class="fw-bold text-dark d-none d-md-inline">
            <i class="bi bi-person-circle me-1 text-primary"></i> @displayDisplayName
        </span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/User/Index"><i class="bi bi-house-door me-2"></i> Ana Sayfa</a>
    <a href="/User/AvailableCars"><i class="bi bi-car-front me-2"></i> Araç Kirala</a>
    <a href="/User/MyRentals"><i class="bi bi-list-check me-2"></i> Kiralamalarım</a>
    <hr class="opacity-25">
    <a href="/User/IncomingRequests?filter=aktif"><i class="bi bi-bell-fill me-2 text-warning"></i> Talepleri Yönet</a>
    <a href="/Car/MyCars"><i class="bi bi-tags me-2"></i> İlanlarım</a>
    <a href="/Car/Create"><i class="bi bi-plus-square me-2"></i> Araç Ekle</a>
    <a href="/User/EditProfile"><i class="bi bi-gear me-2"></i> Ayarlar</a>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-dark m-0"><i class="bi bi-pencil-square text-primary"></i> İlanı Düzenle</h2>
                <a href="@(ViewBag.Role == "Admin" ? "/Admin/CarList" : "/Car/MyCars")" class="btn btn-white shadow-sm rounded-pill border-0 px-4">
                    <i class="bi bi-x-circle me-1"></i> İptal Et
                </a>
            </div>

            <form action="/Car/Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
                @* KRİTİK: Gizli alanlar korunuyor *@
                <input type="hidden" name="Id" value="@Model.Id" />
                <input type="hidden" name="ImagePath" value="@Model.ImagePath" />

                <div class="edit-card card p-5">
                    <h5 class="fw-bold text-secondary mb-4 border-bottom pb-2">Temel Bilgiler</h5>
                    
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Marka</label>
                            <input type="text" name="Brand" value="@Model.Brand" class="form-control rounded-3 shadow-sm" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Model</label>
                            <input type="text" name="ModelName" value="@Model.ModelName" class="form-control rounded-3 shadow-sm" required>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold small">Model Yılı</label>
                            <input type="number" name="ModelYear" value="@Model.ModelYear" class="form-control rounded-3 shadow-sm" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small">Renk</label>
                            <input type="text" name="Color" value="@Model.Color" class="form-control rounded-3 shadow-sm" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small">Konum</label>
                            <input type="text" name="Location" value="@Model.Location" class="form-control rounded-3 shadow-sm" required>
                        </div>
                    </div>
<div class="col-md-4"><input type="text" name="Plate" value="@Model.Plate" class="form-control" readonly>
 </div>
                    <div class="mb-4 p-3 bg-light rounded-4 border border-dashed text-center">
                        <label class="form-label fw-bold text-dark d-block mb-3">Araç Fotoğrafı</label>
                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <div class="mb-3">
                                <img src="@Model.ImagePath" width="200" class="rounded-3 shadow" style="object-fit: cover;" />
                                <div class="mt-2 text-muted small">Mevcut Görsel</div>
                            </div>
                        }
                        <input type="file" name="ImageFile" class="form-control rounded-pill bg-white shadow-sm" accept="image/*">
                        <small class="text-primary mt-2 d-block small">Fotoğrafı değiştirmek istemiyorsanız boş bırakın.</small>
                    </div>

                    <h5 class="fw-bold text-secondary mb-4 border-bottom pb-2">Fiyatlandırma (₺)</h5>
                    <div class="p-4 mb-4 bg-primary bg-opacity-10 rounded-4 border border-primary border-opacity-25">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Günlük</label>
                                <input type="number" step="0.01" name="DailyPrice" value="@Model.DailyPrice" class="form-control rounded-3" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Haftalık</label>
                                <input type="number" step="0.01" name="WeeklyPrice" value="@Model.WeeklyPrice" class="form-control rounded-3" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Aylık</label>
                                <input type="number" step="0.01" name="MonthlyPrice" value="@Model.MonthlyPrice" class="form-control rounded-3" required>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small">Açıklama</label>
                        <textarea name="Description" class="form-control rounded-3 shadow-sm" rows="4" required>@Model.Description</textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 shadow rounded-pill py-3 fw-bold">
                        <i class="bi bi-save-fill me-2"></i> Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }
</script>