@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background: #f4f7fa;
        font-family: 'Segoe UI', sans-serif;
    }

    .verify-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .verify-card {
        width: 100%;
        max-width: 450px;
        border: none;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
        padding: 30px;
        background: white;
        text-align: center;
    }

    .verify-icon {
        font-size: 60px;
        color: #1e3a8a;
        margin-bottom: 15px;
    }

    .verify-title {
        font-weight: 700;
        margin-bottom: 10px;
    }

    .verify-sub {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 25px;
    }

    .code-input {
        font-size: 20px;
        text-align: center;
        letter-spacing: 6px;
        font-weight: bold;
    }

    .btn-primary {
        border-radius: 12px;
        padding: 10px;
        font-weight: 600;
    }

    .email-box {
        background: #eef2ff;
        padding: 10px;
        border-radius: 12px;
        font-size: 14px;
        margin-bottom: 20px;
        color: #1e3a8a;
        word-break: break-word;
    }
</style>

<div class="verify-wrapper">

    <div class="verify-card">

        <i class="bi bi-shield-lock verify-icon"></i>

        <h3 class="verify-title">Email Doğrulama</h3>

        <p class="verify-sub">
            Hesabınızı aktif hale getirmek için e-posta adresinize gönderilen 6 haneli kodu girin.
        </p>

        <div class="email-box">
            📩 @ViewBag.Email
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger py-2">
                @TempData["Error"]
            </div>
        }

        <form method="post" action="/Auth/VerifyEmail">
        @Html.AntiForgeryToken()

            <input type="hidden" name="email" value="@ViewBag.Email" />

            <input type="text"
                   name="code"
                   maxlength="6"
                   class="form-control code-input mb-3"
                   placeholder="------" 
                   required/>

            <button type="submit" class="btn btn-primary w-100">
                Doğrula ve Devam Et
            </button>

        </form>

        <div class="mt-3">
            <small class="text-muted">
                Kod gelmedi mi? <a href="/Auth/ResendCode?email=@ViewBag.Email">Tekrar gönder</a>
            </small>
        </div>

    </div>

</div>