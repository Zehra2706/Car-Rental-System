@using Car_reservation_automation_system.ViewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(to right, #eaeaec, #d3d9e5);
        height: 100vh;
    }

    .login-container {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        background: white;
        padding: 30px;
        border-radius: 15px;
        width: 350px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .login-title {
        text-align: center;
        font-weight: 700;
        margin-bottom: 20px;
        color: #111;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group label {
        font-size: 14px;
        color: #444;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        border-radius: 8px;
        border: 1px solid #ccc;
    }

    .form-control:disabled {
        background: #f3f3f3;
        cursor: not-allowed;
    }

    .btn-login {
        width: 100%;
        padding: 10px;
        background: #2563eb;
        color: white;
        border: none;
        border-radius: 8px;
        margin-top: 10px;
    }

    .btn-login:disabled {
        background: gray;
    }

    .error {
        color: red;
        margin-top: 10px;
        text-align: center;
    }

    .locked {
        color: darkred;
        font-weight: bold;
        text-align: center;
        margin-top: 10px;
    }

    .extra-links {
        text-align: center;
        margin-top: 15px;
        font-size: 14px;
    }

    .extra-links a {
        color: #2563eb;
        text-decoration: none;
    }
</style>

<div class="login-container">
    <div class="login-card">

        <h2 class="login-title">Giriş Yap</h2>

        @* 🔒 Hesap kilitli mesaj *@
        @if (ViewBag.IsLocked != null && ViewBag.IsLocked == true)
        {
            <div class="locked">
                🚫 Hesabınız kilitli! <br />
                Şifrenizi sıfırlamanız gerekiyor.
            </div>
        }

        <form method="post">

            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" class="form-control"
                       disabled="@(ViewBag.IsLocked != null && (bool)ViewBag.IsLocked)" />
            </div>

            <div class="form-group">
                <label>Şifre</label>
                <input asp-for="Password" type="password" class="form-control"
                       disabled="@(ViewBag.IsLocked != null && (bool)ViewBag.IsLocked)" />
            </div>

            <button type="submit" class="btn-login" disabled="@(ViewBag.IsLocked != null && (bool)ViewBag.IsLocked)">
                Giriş Yap
            </button>

            <div class="form-check mb-3">
                <input type="checkbox" asp-for="RememberMe" />
                <label asp-for="RememberMe">Beni hatırla</label>
            </div>
        </form>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger small">
                @Html.Raw(ViewBag.Error)
            </div>
        }

        <div class="extra-links">
            <a href="/Auth/ForgotPassword">Şifremi unuttum</a>
        </div>

        <div class="extra-links">
            Hesabın yok mu?
            <a href="/Auth/Register">Kayıt Ol</a>
        </div>

    </div>
</div>