@using Car_reservation_automation_system.ViewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
}

<style>
    body { margin: 0; font-family: 'Segoe UI', sans-serif; background: linear-gradient(to right, #eaeaec, #d3d9e5); height: 100vh; }
    .login-container { height: 100vh; display: flex; justify-content: center; align-items: center; }
    .login-card { background: white; padding: 30px; border-radius: 15px; width: 380px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1); }
    .login-title { text-align: center; font-weight: 700; margin-bottom: 20px; color: #111; }
    .form-group { margin-bottom: 15px; }
    .form-control { width: 100%; padding: 10px; margin-top: 5px; border-radius: 8px; border: 1px solid #ccc; box-sizing: border-box; }
    .btn-login { width: 100%; padding: 12px; background: #2563eb; color: white; border: none; border-radius: 8px; margin-top: 10px; font-weight: 600; cursor: pointer; transition: all 0.3s; }
    .btn-login:hover:not(:disabled) { background: #1d4ed8; }
    .btn-login:disabled { background: #94a3b8; cursor: not-allowed; }
    .error-box { background: #fee2e2; color: #b91c1c; padding: 12px; border-radius: 8px; border: 1px solid #fecaca; margin-top: 15px; font-size: 13px; text-align: center; }
    .extra-links { text-align: center; margin-top: 15px; font-size: 14px; }
    .extra-links a { color: #2563eb; text-decoration: none; font-weight: 500; }
    .links { text-align: center; margin-top: 20px; font-size: 13px; }
</style>

<div class="login-container">
    <div class="login-card">
        <h2 class="login-title">Giriş Yap</h2>

        <form method="post" id="loginForm">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Email Adresi</label>
                <input asp-for="Email" class="form-control" id="emailInput" placeholder="Örn: melisa@mail.com" required />
            </div>

            <div class="form-group">
                <label>Şifre</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn-login" id="submitBtn" @(ViewBag.IsLocked == true ? "disabled" : "")>
                @(ViewBag.IsLocked == true ? "Hesap Kilitli" : "Giriş Yap")
            </button>
        </form>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                @ViewBag.Error
            </div>
        }

        <div class="extra-links">
            <a href="/Auth/ForgotPassword">Şifremi unuttum?</a>
        </div>
        <div class="extra-links">
            Henüz hesabınız yok mu? <a href="/Auth/Register">Kayıt Ol</a>
        </div>
        <div class="links">
            <a href="/"><i class="fas fa-arrow-left"></i> Ana Sayfaya Dön</a>
        </div>
    </div>
</div>

<script>
    // Kullanıcı email alanını değiştirdiğinde butonu tekrar aktif et
    const emailInput = document.getElementById('emailInput');
    const submitBtn = document.getElementById('submitBtn');

    emailInput.addEventListener('input', function () {
        if (submitBtn.disabled) {
            submitBtn.disabled = false;
            submitBtn.innerText = "Giriş Yap";
        }
    });
</script>