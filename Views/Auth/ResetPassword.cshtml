@using Car_reservation_automation_system.ViewModels
@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Şifre Sıfırla";
}

<div class="container mt-5" style="max-width:400px;">
    <div class="card shadow p-4">

        <h3 class="text-center mb-4">🔒 Yeni Şifre</h3>

        <form method="post" asp-action="ResetPassword" asp-controller="Auth">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <div class="mb-3">
                <label>Yeni Şifre</label>
                <input type="password" asp-for="Password" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Yeni Şifre (Tekrar)</label>
                <input type="password" asp-for="ConfirmPassword" class="form-control" required />
            </div>
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger small">
                    @ViewBag.Error
                </div>
            }
            <button type="submit" class="btn btn-success w-100">
                Şifreyi Güncelle
            </button>
        </form>

        <div class="text-center mt-3">
            <a href="/Auth/Login">← Girişe dön</a>
        </div>

    </div>
</div>