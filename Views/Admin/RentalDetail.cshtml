@model rental.Models.Rental

@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background: #f4f7fa;
    }

    .detail-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .section-title {
        font-size: 14px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .info-box {
        background: #f8fafc;
        border-radius: 12px;
        padding: 12px 15px;
        margin-bottom: 10px;
    }

    .overdue-alert {
        background: #fee2e2;
        color: #991b1b;
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        margin-top: 15px;
    }

    .badge-soft {
        background: #e0f2fe;
        color: #0369a1;
        padding: 5px 10px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
    }
</style>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Kiralama Detayı</h3>
        <a href="/Admin/AllRentalRequests" class="btn btn-light shadow-sm">
            <i class="bi bi-arrow-left"></i> Geri
        </a>
    </div>

    <div class="detail-card">

        <!-- USER INFO -->
        <div class="section-title">Kullanıcı Bilgileri</div>

        <div class="info-box">
            <i class="bi bi-person"></i>
            <strong>@Model.User?.Name @Model.User?.Surname</strong>
        </div>

        <div class="info-box">
            <i class="bi bi-credit-card"></i>
            TC: <strong>@Model.User?.TC</strong>
        </div>

        <div class="info-box">
            <i class="bi bi-envelope"></i>
            @Model.User?.UserInfo?.Email
        </div>

        <div class="info-box">
            <i class="bi bi-telephone"></i>
            @Model.User?.UserConnections?.Number
        </div>

        <div class="info-box">
            <i class="bi bi-house"></i>
            @Model.User?.UserConnections?.Adress
        </div>

        <div class="info-box">
            <i class="bi bi-card-text"></i>
            Ehliyet No: <strong>@Model.User?.Licence?.LicenceNumber</strong>
        </div>

        <hr />

        <!-- CAR INFO -->
        <div class="section-title">Araç Bilgileri</div>

        <div class="info-box">
            🚗 <strong>@Model.Car?.Brand @Model.Car?.ModelName</strong>
        </div>

        <div class="info-box">
            📌 Plaka: <span class="badge-soft">@Model.Car?.Plate</span>
        </div>

        <hr />

        <!-- RENTAL INFO -->
        <div class="section-title">Kiralama Bilgileri</div>

        <div class="info-box">
            📅 Başlangıç: <strong>@Model.Date.ToString("dd.MM.yyyy")</strong>
        </div>

        <div class="info-box">
            📅 Bitiş: <strong>@Model.ReturnDate.ToString("dd.MM.yyyy")</strong>
        </div>

        <div class="info-box">
            💰 Tutar: <strong>@Model.Forecast.ToString("C2")</strong>
        </div>

        <!-- STATUS -->
        <div class="mt-3">
            @if (Model.IsReturned)
            {
                <span class="badge bg-success">Tamamlandı</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">Devam Ediyor</span>
            }
        </div>

        <!-- OVERDUE WARNING -->
        @if (!Model.IsReturned && DateTime.Now.Date > Model.ReturnDate.Date)
        {
            <div class="overdue-alert">
                ⚠️ Süresi geçmiş ama iade alınmamış!
            </div>
        }

    </div>
</div>