@model List<rental.Models.Rental>
@{
    Layout = "_Layout";
    // Kullanıcı adını çekiyoruz
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Admin");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 80px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }
    .topbar-right-area { display: flex; align-items: center; gap: 20px; }
    
    .admin-tag {
        background: #1e3a8a; color: white; padding: 4px 12px;
        border-radius: 50px; font-size: 0.75rem; font-weight: bold;
    }

    .logout-btn-new {
        background: #ef4444; color: white; border: none;
        padding: 8px 16px; border-radius: 10px; font-weight: 600; text-decoration: none;
    }

    /* SIDEBAR (ADMIN DARK) */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #0f172a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.7); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.1); color: white; }

    /* TABLE CARD */
    .admin-table-card {
        border: none;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        overflow: hidden;
    }
    .table thead th {
        background: #f8fafc;
        color: #64748b;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 2px solid #edf2f7;
    }
    tr:hover {
    background-color: #f1f5f9;
    transition: 0.2s;
    }
    .overdue-row {
    background-color: #fee2e2 !important;
    }
    .table tbody tr.overdue-row > td {
    background-color: #fee2e2 !important;
    }
    tr.overdue-row:hover td {
    background-color: #fee2e2 !important;
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area">
        <span class="admin-tag d-none d-sm-inline me-2">SİSTEM YÖNETİCİSİ</span>
        <span class="fw-bold text-dark me-2">@displayDisplayName</span>
    
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0 text-info">Admin Panel</h4>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/Admin/Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/Admin/AllRentalRequests"><i class="bi bi-calendar-check me-2"></i> Kiralama Talepleri</a>
    <a href="/Admin/CarList"><i class="bi bi-car-front me-2"></i> Araç Filosu</a>
    <hr class="opacity-25">
    <a href="/Admin/UserList"><i class="bi bi-people me-2"></i> Kullanıcı Yönetimi</a>
    <a href="/Admin/AdminList"><i class="bi bi-shield-lock me-2"></i> Yetkili Listesi</a>
</div>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">Sistemdeki Tüm Kiralamalar</h2>
            <p class="text-muted small">Global kiralama geçmişini ve anlık durumları buradan izleyebilirsiniz.</p>
        </div>
        <a href="/Admin/Index" class="btn btn-white shadow-sm rounded-pill border-0 px-4">
            <i class="bi bi-arrow-left"></i> Geri Dön
        </a>
    </div>

    <div class="admin-table-card card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 py-3">Müşteri Bilgisi</th>
                        <th class="py-3">Araç</th>
                        <th class="py-3 text-center">Kiralama Aralığı</th>
                        <th class="py-3 text-center">Tutar</th>
                        <th class="py-3 text-center">Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr onclick="window.location='/Admin/RentalDetail/@item.Id'"
                                class="@(item.IsPaid && !item.IsReturned && DateTime.Now.Date > item.ReturnDate.Date ? "overdue-row" : "")"
                                style="cursor:pointer;">                           
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.User?.Name @item.User?.Surname</div>
                                    <small class="text-muted">@item.User?.UserInfo?.Email</small>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.Car?.Brand @item.Car?.ModelName</div>
                                    <span class="badge bg-secondary-subtle text-secondary fw-normal">@item.Car?.Plate</span>
                                </td>
                                <td class="text-center">
                                    <div class="small">
                                        <i class="bi bi-calendar-event text-primary me-1"></i>@item.Date.ToShortDateString()
                                    </div>
                                    <div class="small text-muted">
                                        <i class="bi bi-calendar-check text-danger me-1"></i>@item.ReturnDate.ToShortDateString()
                                    </div>
                                </td>
                                <td class="text-center fw-bold text-primary">@item.Forecast.ToString("C2")</td>
                                <td class="text-center">

                                    @{
                                        var badgeClass = item.Status == "Onaylandı" ? "bg-success-subtle text-success border-success-subtle" : 
                                                        (item.Status == "Reddedildi" ? "bg-danger-subtle text-danger border-danger-subtle" : 
                                                        "bg-warning-subtle text-warning border-warning-subtle");
                                    }

                                    <span class="badge px-3 py-2 border @badgeClass" style="font-weight: 600;">
                                        @item.Status
                                    </span>

                                    <div class="mt-2">

                                        @* 1) KULLANIMDA *@
                                        @if (item.IsPaid && !item.IsReturned && DateTime.Now >= item.Date && DateTime.Now <= item.ReturnDate)
                                        {
                                            <span class="badge bg-info text-white">
                                                Kullanımda
                                            </span>
                                        }

                                        @* 2) İADE BUTONU                        *@
                                        @if (item.IsPaid && !item.IsReturned && DateTime.Now > item.ReturnDate )
                                        {
                                            <form method="post" action="/Admin/ReturnCar" onclick="event.stopPropagation();">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="rentalId" value="@item.Id" />
                                                <button type="submit" class="btn btn-warning btn-sm mt-2">
                                                    İade Al
                                                </button>
                                            </form>
                                        }

                                        @* 3) TAMAMLANDI *@
                                        @if (item.IsReturned)
                                        {
                                            <span class="badge bg-success mt-2">
                                                Tamamlandı
                                            </span>
                                        }

                                    </div>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-database-exclamation display-1 text-muted opacity-25"></i>
                                <p class="text-muted mt-3">Sistemde henüz bir kiralama kaydı bulunmuyor.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }
</script>