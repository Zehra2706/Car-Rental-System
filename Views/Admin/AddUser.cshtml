@model AdminCreateUserViewModel
@{
    Layout = "_Layout";
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession : 
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Admin");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 90px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }
    .topbar-right-area { display: flex; align-items: center; gap: 20px; }
    
    .admin-tag {
        background: #1e3a8a; color: white; padding: 4px 12px;
        border-radius: 50px; font-size: 0.75rem; font-weight: bold;
    }

    .logout-btn-new {
        background: #ef4444; color: white; border: none;
        padding: 8px 16px; border-radius: 10px; font-weight: 600; text-decoration: none;
    }

    /* SIDEBAR (ADMIN DARK) */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #0f172a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.7); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.1); color: white; }

    /* FORM CARD */
    .admin-form-card {
        border: none;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area">
        <span class="admin-tag d-none d-sm-inline me-2">SİSTEM YÖNETİCİSİ</span>
        <span class="fw-bold text-dark me-2">@displayDisplayName</span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0 text-info">Admin Panel</h4>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/Admin/Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/Admin/AllRentalRequests"><i class="bi bi-calendar-check me-2"></i> Kiralama Talepleri</a>
    <a href="/Admin/CarList"><i class="bi bi-car-front me-2"></i> Araç Filosu</a>
    <hr class="opacity-25">
    <a href="/Admin/UserList"><i class="bi bi-people me-2"></i> Kullanıcı Yönetimi</a>
    <a href="/Admin/AdminList"><i class="bi bi-shield-lock me-2"></i> Yetkili Listesi</a>
    <a href="/Admin/AddUser"><i class="bi bi-person-plus-fill me-2 text-info"></i> Yetkili Ekle</a>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-dark m-0"><i class="bi bi-person-plus-fill text-primary"></i> Yeni Yetkili Ekle</h2>
                <a href="/Admin/Index" class="btn btn-white shadow-sm rounded-pill border-0 px-4">
                    <i class="bi bi-arrow-left"></i> Geri Dön
                </a>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
                </div>
            }

            <div class="admin-form-card card p-4 p-md-5">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    @* Ad & Soyad *@
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-secondary">AD</label>
                            <input type="text" name="Name" class="form-control rounded-3 shadow-sm" placeholder="Ad" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-secondary">SOYAD</label>
                            <input type="text" name="Surname" class="form-control rounded-3 shadow-sm" placeholder="Soyad" required />
                        </div>
                    </div>

                    @* Email & Telefon *@
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-secondary">E-POSTA</label>
                            <input type="email" name="Email" class="form-control rounded-3 shadow-sm" placeholder="email@örnek.com" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-secondary">TELEFON</label>
                            <input type="text" name="PhoneNumber" class="form-control rounded-3 shadow-sm" placeholder="05xx" required />
                        </div>
                    </div>

                    @* Adres & Ehliyet *@
                    <div class="row g-3 mb-4">
                        <div class="col-md-8">
                            <label class="form-label fw-bold small text-secondary">ADRES</label>
                            <input type="text" name="Address" class="form-control rounded-3 shadow-sm" placeholder="Tam adres bilgisi" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-secondary">EHLİYET NO</label>
                            <input type="text" name="LicenseNumber" class="form-control rounded-3 shadow-sm" placeholder="123456" required />
                            <span asp-validation-for="LicenseNumber" class="text-danger xsmall"></span>
                        </div>
                    </div>

                    @* Şifre Alanları *@
                    <div class="row g-3 mb-4 p-4 bg-light rounded-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-primary">ŞİFRE</label>
                            <input type="password" name="Password" class="form-control rounded-3 shadow-sm" placeholder="••••••••" required />
                            <span asp-validation-for="Password" class="text-danger xsmall"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-primary">ŞİFRE TEKRAR</label>
                            <input type="password" name="ConfirmPassword" class="form-control rounded-3 shadow-sm" placeholder="••••••••" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger xsmall"></span>
                        </div>
                    </div>

                    <input type="hidden" name="UserRole" value="1" />

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3 fw-bold shadow">
                        <i class="bi bi-save2-fill me-2"></i> Yetkiliyi Kaydet
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleMenu() {
            document.getElementById("sidebar").classList.toggle("active");
        }
    </script>
}