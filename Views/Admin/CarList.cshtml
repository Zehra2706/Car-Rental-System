@model List<car.Models.Car>

@{
    Layout = "_Layout";
}

<div class="container mt-5">

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary">🚗 Araç Listesi</h2>
    <div>
        <button class="btn btn-dark me-2"
                data-bs-toggle="offcanvas"
                data-bs-target="#filterSidebar">
            🔍 Filtrele
        </button>

        <a href="/Admin/Index" class="btn btn-secondary">← Geri Dön</a>
    </div>
<form method="get" action="/Car/UserList" class="mb-3">

    <div class="input-group">
        <input type="text"
               name="search"
               value="@Context.Request.Query["search"]"
               class="form-control"
               placeholder="Ara (marka, model, plaka)">

        <button class="btn btn-primary" type="submit">
            🔍 Ara
        </button>
    </div>

</form>
</div>
<div class="offcanvas offcanvas-end" tabindex="-1" id="filterSidebar" style="width:320px;">

    <!-- HEADER -->
    <div class="offcanvas-header">
        <h5 class="offcanvas-title fw-bold text-primary">
            🔍 Filtrele
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <!-- BODY -->
    <div class="offcanvas-body">

        <form method="get" action="/Car/AdminList">

            <!-- MARKA -->
            <div class="mb-3">
                <label>Marka</label>
                <input type="text" name="Brand" class="form-control">
            </div>
            
            <!-- MODEL -->
            <div class="mb-3">
                <label>Model</label>
                <input type="text" name="ModelName" class="form-control">
            </div>

            <!-- YIL -->
            <div class="mb-3">
                <label>Model Yılı</label>
                <div class="d-flex gap-2">
                    <input type="number" name="MinYear" class="form-control" placeholder="Min">
                    <input type="number" name="MaxYear" class="form-control" placeholder="Max">
                </div>
            </div>

            <!-- VİTES -->
            <div class="mb-3">
                <label>Vites</label>
                <select name="Transmission" class="form-control">
                    <option value="">Hepsi</option>
                    <option value="0">Manuel</option>
                    <option value="1">Otomatik</option>
                </select>
            </div>

            <!-- YAKIT -->
            <div class="mb-3">
                <label>Yakıt</label>
                <select name="FuelType" class="form-control">
                    <option value="">Hepsi</option>
                    <option value="0">Benzin</option>
                    <option value="1">Dizel</option>
                    <option value="2">Elektrik</option>
                </select>
            </div>

            <!-- ŞOFÖR -->
            <div class="mb-3">
                <label>Şoför</label>
                <select name="IsChauffeured" class="form-control">
                    <option value="">Hepsi</option>
                    <option value="true">Var</option>
                    <option value="false">Yok</option>
                </select>
            </div>

                        <!-- FİYAT TİPİ -->
            <div class="mb-3">
                <label>Fiyat Türü</label>
                <select name="PriceType" class="form-control">
                    <option value="daily">Günlük</option>
                    <option value="weekly">Haftalık</option>
                    <option value="monthly">Aylık</option>
                </select>
            </div>

            <!-- FİYAT ARALIĞI -->
            <div class="mb-3">
                <label>Fiyat Aralığı</label>
                <div class="d-flex gap-2">
                    <input type="number" name="MinPrice" class="form-control" placeholder="Min ₺">
                    <input type="number" name="MaxPrice" class="form-control" placeholder="Max ₺">
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Filtrele
            </button>

        </form>
    </div>
</div>
@if (Model == null || !Model.Any())
{
    <div class="text-center mt-5">
        <h4 class="text-danger">Filtreye uygun araç bulunamadı</h4>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var car in Model)
        {
            <!-- kart -->
        }
    </div>
}
@* @if (Context.Request.Query.Any())
{
    <div class="mb-3">
        <span class="badge bg-primary">Filtre aktif</span>
    </div>
} *@

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-lg border-0 h-100">

                    <!-- 📸 FOTO -->
                    <img src="@(item.ImagePath ?? "/images/no-image.png")"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body">

                        <h5 class="card-title text-primary">
                            @item.Brand @item.ModelName
                        </h5>

                        <p class="card-text text-muted">
                            📅 @item.ModelYear <br />
                            📍 @item.Location
                        </p>

                        <!-- 💰 FİYAT -->
                        @if (item.Prices != null && item.Prices.Any())
                        {
                            var p = item.Prices.FirstOrDefault();

                            <div class="mb-2">
                                <span class="badge bg-success fs-6">
                                    @p.daily ₺ / Gün
                                </span>
                            </div>

                            <small class="text-muted">
                                Haftalık: @p.weekly ₺ <br />
                                Aylık: @p.monthly ₺
                            </small>
                        }
                        else
                        {
                            <span class="text-danger">Fiyat yok</span>
                        }

                    </div>

                    <div class="card-footer bg-white border-0 text-center">

                        <!-- EDIT -->
                        <a href="/Car/Edit/@item.Id" class="btn btn-sm btn-primary me-2">
                            ✏️ Düzenle
                        </a>

                        <!-- DELETE -->
                        <form action="/Admin/DeleteCar/@item.Id" method="post" style="display:inline;">
                            <button type="submit"
                                    class="btn btn-sm btn-danger"
                                    onclick="return confirm('Bu aracı silmek istediğine emin misin?')">
                                🗑 Sil
                            </button>
                        </form>

                    </div>

                </div>
            </div>
        }
    </div>

</div>
<a href="/Admin/Index">Çıkış Yap</a>
<script>
    function toggleFilter() {
        var box = document.getElementById("filterBox");

        if (box.style.display === "none") {
            box.style.display = "block";
        } else {
            box.style.display = "none";
        }
    }

    // 🔥 CANLI ARAMA BURASI
    document.getElementById("searchBox").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();

        document.querySelectorAll(".card").forEach(card => {
            card.style.display =
                card.innerText.toLowerCase().includes(value)
                ? ""
                : "none";
        });
    });
</script>
