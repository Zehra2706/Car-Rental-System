@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}
@model List<car.Models.Car>
@{
    Layout = "_Layout";
    // Kullanıcı adını çekiyoruz
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Admin");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 80px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }
    .topbar-right-area { display: flex; align-items: center; gap: 20px; }
    
    .admin-tag {
        background: #1e3a8a; color: white; padding: 4px 12px;
        border-radius: 50px; font-size: 0.75rem; font-weight: bold;
    }

    .logout-btn-new {
        background: #ef4444; color: white; border: none;
        padding: 8px 16px; border-radius: 10px; font-weight: 600; text-decoration: none;
    }

    /* SIDEBAR (ADMIN DARK) */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #0f172a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.7); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.1); color: white; }

    /* CAR CARDS */
    .admin-car-card {
        border: none;
        border-radius: 20px;
        transition: all 0.3s ease;
        background: white;
    }
    .admin-car-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area">
        <span class="admin-tag d-none d-sm-inline">SİSTEM YÖNETİCİSİ</span>
        <span class="fw-bold text-dark">@displayDisplayName</span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0 text-info">Admin Panel</h4>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/Admin/Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/Admin/AllRentalRequests"><i class="bi bi-calendar-check me-2"></i> Kiralama Talepleri</a>
    <a href="/Admin/CarList"><i class="bi bi-car-front me-2"></i> Araç Filosu</a>
    <hr class="opacity-25">
    <a href="/Admin/UserList"><i class="bi bi-people me-2"></i> Kullanıcı Yönetimi</a>
    <a href="/Admin/AdminList"><i class="bi bi-shield-lock me-2"></i> Yetkili Listesi</a>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark m-0">🚗 <span class="text-primary">Araç Listesi Yönetimi</span></h2>
        <a href="/Admin/Index" class="btn btn-outline-secondary rounded-pill px-4 btn-sm">
            <i class="bi bi-arrow-left"></i> Geri Dön
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-auto">
            <button class="btn btn-dark rounded-pill px-4 shadow-sm" data-bs-toggle="offcanvas" data-bs-target="#filterSidebar">
                <i class="bi bi-funnel-fill me-2"></i>Filtrele
            </button>
        </div>
        <div class="col-md">
            <form method="get" action="/Car/AdminList">
                @Html.AntiForgeryToken()
                <div class="input-group shadow-sm rounded-pill overflow-hidden border bg-white">
                    <input type="text" id="searchBox" name="search" value="@Context.Request.Query["search"]"
                           class="form-control border-0 px-4" placeholder="Marka, model veya plaka ile hızlı ara...">
                    <button class="btn btn-primary px-4" type="submit">🔍 Ara</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col car-item">
                    <div class="card h-100 admin-car-card shadow-sm overflow-hidden">
                        <img src="@(item.ImagePath ?? "/images/no-image.png")" class="card-img-top" style="height:200px; object-fit:cover;" />
                        
                        <div class="card-body p-4">
                            <h5 class="fw-bold text-primary text-uppercase mb-2">@item.Brand @item.ModelName</h5>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-calendar3 me-1"></i> @item.ModelYear | <i class="bi bi-geo-alt-fill text-danger me-1"></i> @item.Location
                            </p>

                            <div class="p-3 bg-light rounded-4 mb-3">
                                @if (item.Prices != null && item.Prices.Any())
                                {
                                    var p = item.Prices.FirstOrDefault();
                                    <div class="d-flex justify-content-between mb-1">
                                        <small class="fw-bold text-secondary">Günlük:</small>
                                        <span class="text-success fw-bold">@p.daily.ToString("N0") ₺</span>
                                    </div>
                                    <div class="d-flex justify-content-between small opacity-75">
                                        <small>Haftalık / Aylık:</small>
                                        <span>@p.weekly ₺ / @p.monthly ₺</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 d-flex gap-2 p-4 pt-0">
                            <a href="/Car/Edit/@item.Id" class="btn btn-primary btn-sm flex-fill rounded-pill">
                                <i class="bi bi-pencil-square"></i> Düzenle
                            </a>
                            <form action="/Admin/DeleteCar/@item.Id" method="post" class="flex-fill">
                                @Html.AntiForgeryToken()    
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill"
                                        onclick="return confirm('Bu aracı silmek istediğine emin misin?')">
                                    <i class="bi bi-trash3"></i> Sil
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-search display-1 text-muted opacity-25"></i>
                <h4 class="mt-3 text-secondary">Uygun araç bulunamadı.</h4>
            </div>
        }
    </div>
</div>

<div class="offcanvas offcanvas-start" tabindex="-1" id="filterSidebar" style="width:340px;">
    <div class="offcanvas-header bg-dark text-white">
        <h5 class="offcanvas-title fw-bold">🔍 Detaylı Filtre</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <form method="get" action="/Car/AdminList">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label small fw-bold">Marka</label>
                <input type="text" name="Brand" class="form-control rounded-3" placeholder="Örn: BMW">
            </div>
            <div class="mb-3">
                <label class="form-label small fw-bold">Model</label>
                <input type="text" name="ModelName" class="form-control rounded-3">
            </div>
            <div class="mb-3">
                <label class="form-label small fw-bold">Model Yılı Aralığı</label>
                <div class="d-flex gap-2">
                    <input type="number" name="MinYear" class="form-control" placeholder="Min">
                    <input type="number" name="MaxYear" class="form-control" placeholder="Max">
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label small fw-bold">Şanzıman / Yakıt / Şoför</label>
                <select name="Transmission" class="form-select mb-2 rounded-3">
                    <option value="">Vites Tipi(Hepsi)</option>
                    <option value="0">Manuel</option>
                    <option value="1">Otomatik</option>
                </select>
                <select name="FuelType" class="form-select mb-2 rounded-3">
                    <option value="">Yakıt (Hepsi)</option>
                    <option value="0">Benzin</option>
                    <option value="1">Dizel</option>
                    <option value="2">Elektrik</option>
                </select>
                <select name="IsChauffeured" class="form-select rounded-3">
                    <option value="">Şoförlü (Hepsi)</option>
                    <option value="true">Var</option>
                    <option value="false">Yok</option>
                </select>
            </div>
            <div class="mb-4">
                <label class="form-label small fw-bold">Fiyat Türü ve Aralığı</label>
                <select name="PriceType" class="form-select mb-2 rounded-3">
                    <option value="daily">Günlük</option>
                    <option value="weekly">Haftalık</option>
                    <option value="monthly">Aylık</option>
                </select>
                <div class="d-flex gap-2">
                    <input type="number" name="MinPrice" class="form-control" placeholder="Min ₺">
                    <input type="number" name="MaxPrice" class="form-control" placeholder="Max ₺">
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill">Filtreleri Uygula</button>
        </form>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }

    // Canlı Arama
    document.getElementById("searchBox").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        document.querySelectorAll(".car-item").forEach(item => {
            item.style.display = item.innerText.toLowerCase().includes(value) ? "" : "none";
        });
    });
</script>