@{
    ViewData["Title"] = "Admin Kontrol Paneli";
    Layout = "_Layout";

    // Kullanıcı adını çekiyoruz
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Admin");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 80px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }
    .topbar-right-area { display: flex; align-items: center; gap: 20px; }
    
    .admin-tag {
        background: #1e3a8a;
        color: white;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: bold;
        margin-right: 8px;
    }

    .logout-btn-new {
        background: #ef4444; color: white; border: none;
        padding: 8px 16px; border-radius: 10px; font-weight: 600; text-decoration: none;
    }

    /* SIDEBAR */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #0f172a; /* Admin için daha koyu bir ton */
        color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.7); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.1); color: white; }

    /* DASHBOARD CARDS */
    .admin-card {
        transition: all 0.3s ease;
        border: none;
        border-radius: 20px;
        background: white;
        height: 100%;
    }
    .admin-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
    }
    .header-section-admin {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area">
        <span class="admin-tag">SİSTEM YÖNETİCİSİ</span>
        <span class="fw-bold text-dark d-none d-md-inline">
             @displayDisplayName
        </span>
        <a href="/Auth/Logout" class="logout-btn-new bi bi-power">Çıkış Yap</a>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0 text-info">Admin Panel</h4>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/Admin/Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/Admin/AllRentalRequests"><i class="bi bi-calendar-check me-2"></i> Kiralama Talepleri</a>
    <a href="/Admin/CarList"><i class="bi bi-car-front me-2"></i> Araç Filosu</a>
    <hr class="opacity-25">
    <a href="/Admin/UserList"><i class="bi bi-people me-2"></i> Kullanıcı Yönetimi</a>
    <a href="/Admin/AdminList"><i class="bi bi-shield-lock me-2"></i> Yetkili Listesi</a>
    <a href="/Admin/AddUser"><i class="bi bi-person-plus me-2"></i> Yeni Yetkili Ekle</a>
</div>

<div class="container py-4">
    <div class="header-section-admin mb-5 p-5 text-white rounded-4 shadow-lg position-relative overflow-hidden">
        <div style="position:relative; z-index: 2;">
            <h1 class="fw-bold">Hoş geldin, @displayDisplayName </h1>
            <p class="lead opacity-75">Sistemdeki tüm araç, kullanıcı ve kiralama süreçlerini buradan yönetebilirsiniz.</p>
        </div>
        <i class="bi bi-shield-shaded position-absolute" style="right: -20px; bottom: -20px; font-size: 150px; opacity: 0.1;"></i>
    </div>
        <div class="d-flex justify-content-end mb-4">
        <a href="/Admin/PastRentals" class="btn btn-dark rounded-pill px-4">
            <i class="bi bi-clock-history me-2"></i> Geçmiş Kiralamalar
        </a>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="admin-card card shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3">
                        <i class="bi bi-calendar-check fs-1 text-primary"></i>
                    </div>
                    <h4 class="fw-bold">Kiralama Yönetimi</h4>
                    <p class="text-muted small">Tüm talepleri onayla, reddet veya iade durumlarını izle.</p>
                    <a href="/Admin/AllRentalRequests" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">Talepleri Listele</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-card card shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3">
                        <i class="bi bi-car-front fs-1 text-success"></i>
                    </div>
                    <h4 class="fw-bold">Araç Yönetimi</h4>
                    <p class="text-muted small">Mevcut araçları düzenle, aktiflik durumlarını kontrol et.</p>
                    <a href="/Admin/CarList" class="btn btn-success w-100 rounded-pill py-2 fw-bold">Araçları Listele</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-card card shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3">
                        <i class="bi bi-people fs-1 text-warning"></i>
                    </div>
                    <h4 class="fw-bold">Kullanıcı & Admin</h4>
                    <p class="text-muted small">Üyeleri yönet, yeni yetkililer ata ve rolleri düzenle.</p>
                    <div class="d-grid gap-2">
                        <div class="d-flex gap-2 mt-1">
                            <a href="/Admin/UserList" class="btn btn-dark btn-sm flex-fill rounded-pill">Kullanıcılar</a>
                             </div>
                       <div class="d-flex gap-2 mt-1">
                            <a href="/Admin/AdminList" class="btn btn-dark btn-sm flex-fill rounded-pill">Adminler</a>
                            <a href="/Admin/AddUser" class="btn btn-dark btn-sm flex-fill rounded-pill">Yetkili Ekle</a>
                        </div>
                        <div>
                             <a href="/Admin/ManageReviews" class="btn btn-dark btn-sm flex-fill rounded-pill">Kullanıcıların Yorumları ve Değerlendirmeleri</a>
                      
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }
</script>