@model List<user.Models.User>
@{
    Layout = "_Layout";
    // Kullanıcı adını çekiyoruz
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Admin");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 80px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }
    .topbar-right-area { display: flex; align-items: center; gap: 20px; }
    
    .admin-tag {
        background: #1e3a8a; color: white; padding: 4px 12px;
        border-radius: 50px; font-size: 0.75rem; font-weight: bold;
    }

    .logout-btn-new {
        background: #ef4444; color: white; border: none;
        padding: 8px 16px; border-radius: 10px; font-weight: 600; text-decoration: none;
    }

    /* SIDEBAR (ADMIN DARK) */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #0f172a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.7); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.1); color: white; }

    /* USER TABLE CARD */
    .user-table-card {
        border: none;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        overflow: hidden;
    }
    .table thead th {
        background: #f8fafc;
        color: #64748b;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 2px solid #edf2f7;
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area">
        <span class="admin-tag d-none d-sm-inline me-2">SİSTEM YÖNETİCİSİ</span>
        <span class="fw-bold text-dark me-2">@displayDisplayName</span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0 text-info">Admin Panel</h4>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/Admin/Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/Admin/AllRentalRequests"><i class="bi bi-calendar-check me-2"></i> Kiralama Talepleri</a>
    <a href="/Admin/CarList"><i class="bi bi-car-front me-2"></i> Araç Filosu</a>
    <hr class="opacity-25">
    <a href="/Admin/UserList"><i class="bi bi-people me-2"></i> Kullanıcı Yönetimi</a>
    <a href="/Admin/AdminList"><i class="bi bi-shield-lock me-2"></i> Yetkili Listesi</a>
</div>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="bi bi-people-fill text-primary"></i> Sistem Kullanıcıları</h2>
            <p class="text-muted small">Tüm kayıtlı üyeleri görüntüleyebilir ve hesap yönetimini yapabilirsiniz.</p>
        </div>
        <a href="/Admin/Index" class="btn btn-white shadow-sm rounded-pill border-0 px-4">
            <i class="bi bi-arrow-left"></i> Geri Dön
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="user-table-card card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 py-3">Profil</th>
                        <th class="py-3">E-posta Adresi</th>
                        <th class="py-3 text-center">Durum</th>
                        <th class="py-3 text-center">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <div class="fw-bold text-dark">@item.Name</div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted"><i class="bi bi-envelope me-1"></i> @item.UserInfo?.Email</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill border border-success-subtle" style="font-size: 0.7rem;">Aktif Üye</span>
                                </td>
                                <td class="text-center">
                                    <form action="/Admin/DeleteUser/@item.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold"
                                                onclick="return confirm('Bu kullanıcıyı sistemden tamamen silmek istediğine emin misin?')">
                                            <i class="bi bi-trash3 me-1"></i> Sil
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-people display-1 opacity-25"></i>
                                <p class="mt-3">Sistemde kayıtlı kullanıcı bulunmuyor.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }
</script>