@model rental.Models.Rental

@{
    Layout = "_Layout";

    // --- CEZA HESAPLAMA MANTIĞI (Decimal Düzeni) ---
    decimal penalty = 0m;
    int delayDays = 0;
    DateTime now = DateTime.Now;

    // 🚩 Model.Forecast artık decimal olduğu için işlemleri decimal tipinde yapıyoruz
    if (now > Model.ReturnDate)
    {
        var timeDiff = now - Model.ReturnDate;
        delayDays = timeDiff.Days;

        // double olan TotalHours'u decimal'a çevirerek kontrol ediyoruz
        if (delayDays <= 0 && (decimal)timeDiff.TotalHours > 0m)
        {
            delayDays = 1;
        }

        // 🚩 0.10m kullanarak çarpıyoruz (decimal dünyası)
        penalty = (decimal)delayDays * (Model.Forecast * 0.10m);
    }

    // Toplam ödenecek tutar (Decimal + Decimal)
    decimal totalAmount = Model.Forecast + penalty;
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 mx-auto rounded-4" style="max-width: 600px;">
        <div class="card-header bg-dark text-white text-center py-3 rounded-top-4">
            <h4 class="mb-0"><i class="bi bi-arrow-repeat me-2"></i> İade ve Ödeme Özeti</h4>
        </div>
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h5 class="text-primary fw-bold text-uppercase mb-1">
                    @Model.Car?.Brand @Model.Car?.ModelName
                </h5>
                <small class="text-muted">Plaka: @(Model.Car?.Plate ?? "---")</small>
            </div>

            <div class="list-group list-group-flush mb-4">
                <div class="list-group-item d-flex justify-content-between align-items-center px-0 border-0">
                    <span class="text-secondary">Normal Kiralama Bedeli:</span>
                    <span class="fw-bold">@Model.Forecast.ToString("C2")</span>
                </div>

                @if (penalty > 0)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0 border-0 text-danger">
                        <span>
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> 
                            Gecikme Cezası (@delayDays Gün - %10 Faiz):
                        </span>
                        <span class="fw-bold">+ @penalty.ToString("C2")</span>
                    </div>
                }
            </div>

            <div class="p-3 bg-light rounded-3 border mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="h5 mb-0 fw-bold">Toplam Ödenecek:</span>
                    <span class="h4 mb-0 fw-bold text-success">@totalAmount.ToString("C2")</span>
                </div>
            </div>

            <form asp-controller="Rental" asp-action="StartReturnPayment" method="post">
                <input type="hidden" name="rentalId" value="@Model.Id" />
                
                <div class="alert alert-warning border-0 small mb-4 shadow-sm">
                    <i class="bi bi-shield-lock-fill me-2"></i>
                    Ödemeniz <strong>iyzico</strong> güvenli ödeme altyapısı ile şifrelenerek tahsil edilecektir.
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 py-3 fw-bold rounded-pill shadow">
                    <i class="bi bi-credit-card-2-front me-2"></i> Ödemeyi Yap ve İadeyi Tamamla
                </button>
            </form>
            
            <div class="text-center mt-3">
                <a asp-action="MyRentals" asp-controller="User" class="text-decoration-none small text-muted">
                    <i class="bi bi-chevron-left"></i> Vazgeç ve Listeye Dön
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .card { transition: transform 0.3s; }
    .card:hover { transform: translateY(-5px); }
    .rounded-4 { border-radius: 1rem !important; }
    .rounded-top-4 { border-top-left-radius: 1rem !important; border-top-right-radius: 1rem !important; }
</style>