@model List<rental.Models.Rental>
@{
    Layout = "_Layout";
    bool isAktifMod = Context.Request.Query["filter"] == "aktif";
    var sayfaBasligi = isAktifMod ? "Onay Bekleyen Talepler" : "Tüm Gelen Talepler Geçmişi";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-envelope-exclamation text-danger"></i> @sayfaBasligi</h2>
        <a href="/User/Index" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="bi bi-arrow-left"></i> Panele Dön
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4 py-3">Araç</th>
                            <th class="py-3">Müşteri</th>
                            <th class="py-3">Tarih Aralığı</th>
                            <th class="py-3">Kazanç</th>
                            <th class="py-3">Durum</th>
                            @if (isAktifMod)
                            {
                                <th class="text-center py-3">İşlem</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark">@item.Car?.Brand @item.Car?.ModelName</div>
                                        <small class="text-muted">@item.Car?.Plate</small>
                                    </td>
                                    <td>
                                        <div class="small">@item.User?.UserInfo?.Email</div>
                                    </td>
                                    <td>
                                        <div class="small">@item.Date.ToShortDateString() - @item.ReturnDate.ToShortDateString()
                                        </div>
                                    </td>
                                    <td class="fw-bold text-success">@item.Forecast.ToString("C2")</td>
                                    <td>
                                        @if (item.Status == "OnayBekliyor")
                                        {
                                            <span
                                                class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">Onay
                                                Bekliyor</span>
                                            }
                                        else if (item.Status == "Onaylandı")
                                            {
                                                <span
                                                class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">Onaylandı</span>
                                            }
                                            else if (item.Status == "Reddedildi")
                                            {
                                                <span
                                                class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">Reddedildi</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-dark border px-3 py-2">@item.Status</span>
                                            }
                                        </td>
                                    
                                        @if (isAktifMod)
                                        {
                                            <td class="text-center">
                                                @if (item.Status == "OnayBekliyor")
                                                {
                                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                                        <form asp-action="UpdateRequestStatus" asp-controller="User" method="post"
                                                              style="display:inline;">
                                                            <input type="hidden" name="rentalId" value="@item.Id" />
                                                            <input type="hidden" name="status" value="Onaylandı" />
                                                            <button type="submit"
                                                                    class="btn btn-sm btn-success px-3 border-0">Onayla</button>
                                                        </form>
                                                        <form asp-action="UpdateRequestStatus" asp-controller="User" method="post"
                                                              style="display:inline;">
                                                            <input type="hidden" name="rentalId" value="@item.Id" />
                                                            <input type="hidden" name="status" value="Reddedildi" />
                                                            <button type="submit"
                                                                    class="btn btn-sm btn-danger px-3 border-0">Reddet</button>
                                                        </form>
                                                    </div>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                        else
                            {
                                <tr>
                                    <td colspan="@(isAktifMod ? 6 : 5)" class="text-center py-5">
                                        <div class="text-muted opacity-50">
                                            <i class="bi bi-inbox-fill display-4"></i>
                                            <p class="mt-2">Gösterilecek bir talep bulunmuyor.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>