@{
    Layout = "_Layout";
    // Session'dan ismi alıyoruz, eğer boşsa fallback olarak e-postayı parçalıyoruz.
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    
    // Eğer UserName session'da varsa onu kullan, yoksa Email'in @ öncesini al.
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Değerli Üyemiz");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 70px;
        /* Topbar yüksekliği kadar boşluk */
    }

    /* TOPBAR - TAM KÖŞELERE SABİTLEME */
    .custom-topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        /* Yanlardan boşluk */
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.08);
        z-index: 2000;
    }

    /* SOL ÜST ☰ */
    .topbar-left-btn {
        font-size: 30px;
        cursor: pointer;
        color: #1e3a8a;
        user-select: none;
    }

    /* SAĞ ÜST KULLANICI & ÇIKIŞ */
    .topbar-right-area {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .user-name-tag {
        font-weight: 600;
        color: #334155;
        font-size: 1.1rem;
    }

    .logout-btn-new {
        background: #ef4444;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .logout-btn-new:hover {
        background: #dc2626;
        color: white;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    }

    /* SIDEBAR */
    .sidebar {
        position: fixed;
        left: -280px;
        top: 0;
        width: 280px;
        height: 100%;
        background: #1e3a8a;
        color: white;
        padding: 25px;
        transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 3000;
    }

    .sidebar.active {
        left: 0;
    }

    .sidebar a {
        display: block;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        padding: 12px 15px;
        margin: 10px 0;
        border-radius: 10px;
    }

    .sidebar a:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }

    /* CONTENT KARTLARIMIZ */
    .action-card {
        transition: transform 0.3s ease;
        border: none;
        height: 100%;
    }

    .action-card:hover {
        transform: translateY(-5px);
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>

    <div class="topbar-right-area">
      
        <a href="/Auth/Logout" class="logout-btn-new">
            <i class="bi bi-power"></i> Çıkış Yap
        </a>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/User/Index"><i class="bi bi-house-door me-2"></i> Dashboard</a>
    <a href="/User/AvailableCars"><i class="bi bi-car-front me-2"></i> Araç Kirala</a>
    <a href="/User/MyRentals"><i class="bi bi-list-check me-2"></i> Kiralamalarım</a>
    <hr class="opacity-25">
    <a href="/User/IncomingRequests?filter=aktif"><i class="bi bi-bell-fill me-2 text-warning"></i> Talepleri Yönet</a>
    <a href="/Car/MyCars"><i class="bi bi-tags me-2"></i> İlanlarım</a>
    <a href="/Car/Create"><i class="bi bi-plus-square me-2"></i> Araç Ekle</a>
    <a href="/User/EditProfile"><i class="bi bi-gear me-2"></i> Ayarlar</a>
</div>

<div class="container py-4">

    <div class="p-5 text-white rounded-4 shadow mb-5" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6);">
        <h1 class="display-5 fw-bold">Hoş geldin, @displayDisplayName</h1>
        <p class="fs-5 opacity-75">Sistemin kontrolü tamamen senin elinde.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="row g-4">
                
                <div class="col-md-6">
                    <a href="/User/IncomingRequests?filter=aktif" class="text-decoration-none">
                        <div class="action-card p-4 rounded-4 bg-white shadow-sm border-top border-danger border-4">
                            <i class="bi bi-bell-fill text-danger display-5 mb-3 d-block"></i>
                            <h5 class="fw-bold text-dark">Onay Bekleyenler</h5>
                            <p class="text-muted small">Araçlarına gelen yeni kiralama isteklerini onayla.</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-6">
                    <a href="/User/MyRentals?filter=aktif" class="text-decoration-none">
                        <div
                            class="action-card p-4 rounded-4 bg-white shadow-sm h-100 border-0 border-top border-warning border-4">
                            <i class="bi bi-hourglass-split text-warning display-6 mb-3 d-block"></i>
                            <h5 class="fw-bold text-dark">Aktif İşlemlerim</h5>
                            <p class="text-muted small">Onay bekleyen taleplerin ve aktif kiraların.</p>
                        </div>
                    </a>
                </div>

                <div class="col-md-6">
                    <a href="/User/IncomingRequests" class="text-decoration-none">
                        <div class="action-card p-4 rounded-4 bg-white shadow-sm border-top border-dark border-4">
                            <i class="bi bi-archive-fill text-dark display-5 mb-3 d-block"></i>
                            <h5 class="fw-bold text-dark">Gelen Talep Geçmişi</h5>
                            <p class="text-muted small">Senin araçların için yapılmış tüm eski kayıtlar.</p>
                        </div>
                    </a>
                </div>

                <div class="col-md-6">
                    <a href="/User/AvailableCars" class="text-decoration-none">
                        <div class="action-card p-4 rounded-4 bg-white shadow-sm">
                            <i class="bi bi-search text-primary display-6 mb-2 d-block"></i>
                            <h6 class="fw-bold text-dark">Hızlı Araç Kirala</h6>
                        </div>
                    </a>
                </div>

                <div class="col-md-6">
                    <a href="/User/MyRentals" class="text-decoration-none">
                        <div class="action-card p-4 rounded-4 bg-white shadow-sm">
                            <i class="bi bi-clock-history text-secondary display-6 mb-2 d-block"></i>
                            <h6 class="fw-bold text-dark">Kiralama Geçmişim</h6>
                        </div>
                    </a>
                </div>

            </div>
        </div>

        <div class="col-lg-4">
            <div class="d-grid gap-3">
                <a href="/Car/Create" class="btn btn-dark p-3 rounded-4 fw-bold shadow-sm">
                    <i class="bi bi-plus-circle me-2"></i>Yeni İlan Ver
                </a>
                <a href="/Car/MyCars" class="btn btn-outline-primary p-3 rounded-4 bg-white shadow-sm">
                    <i class="bi bi-car-front-fill me-2"></i>Araçlarımı Yönet
                </a>
                <a href="/User/EditProfile" class="btn btn-outline-secondary p-3 rounded-4 bg-white shadow-sm">
                    <i class="bi bi-pencil-square me-2"></i>Profilimi Güncelle
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleMenu() {
        var sidebar = document.getElementById("sidebar");
        sidebar.classList.toggle("active");
    }
</script>