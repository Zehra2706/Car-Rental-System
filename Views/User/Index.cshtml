@{
    Layout = "_Layout";
    var userEmail = Context.Session.GetString("UserEmail");
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Hoş Geldin, <span class="text-primary">@userEmail</span>!</h2>
            <p class="text-muted">Hesabını buradan yönetebilir ve araç kiralama işlemlerini takip edebilirsin.</p>
        </div>
        <img src="https://ui-avatars.com/api/?name=Melisa&background=0D6EFD&color=fff" class="rounded-circle shadow"
             width="60" alt="Profil">
    </div>

    <hr>

    <div class="row g-4">
        
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-3">
                <div class="card-body">
                    <i class="bi bi-person-gear display-4 text-primary"></i>
                    <h5 class="card-title mt-3">Profilimi Düzenle</h5>
                    <p class="card-text text-muted small">Kişisel bilgilerini ve iletişim tercihlerini güncelle.</p>
                    <a href="/User/EditProfile" class="btn btn-primary w-100">Düzenle</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-3">
                <div class="card-body">
                    <i class="bi bi-plus-circle display-4 text-success"></i>
                    <h5 class="card-title mt-3">Yeni Araç Ekle</h5>
                    <p class="card-text text-muted small">Sisteme yeni bir kiralık araç tanımla (Admin Yetkisi).</p>
                    <a href="/Car/Create" class="btn btn-success w-100">Araç Ekle</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-3">
                <div class="card-body">
                    <i class="bi bi-car-front display-4 text-warning"></i>
                    <h5 class="card-title mt-3">Kiralamalarım</h5>
                    <p class="card-text text-muted small">Geçmiş ve aktif araç kiralama kayıtlarını incele.</p>
                    <a href="/User/MyRentals" class="btn btn-warning text-white w-100">Görüntüle</a>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-5">
        <div class="col-12">
            <div class="p-4 bg-light rounded-3 border">
                <h5>Hızlı Bakış</h5>
                <div class="d-flex gap-4 mt-2">
                    <span class="badge bg-secondary">Aktif Kiralama: 1</span>
                    <span class="badge bg-info">Tamamlanan: 5</span>
                    <span class="badge bg-dark">Cüzdan: 450 ₺</span>
                </div>
            </div>
        </div>
    </div>
</div>