@model List<car.Models.Car>
@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">🚗 <span class="text-primary">Kiralık Araç Filomuz</span></h2>
            <p class="text-muted">Size en uygun aracı seçin ve detaylarını inceleyin.</p>
        </div>
        <a href="/User/Index" class="btn btn-outline-secondary shadow-sm rounded-pill">
            <i class="bi bi-arrow-left"></i> Panele Dön
        </a>
    </div>
<form method="get" action="/Car/UserList" class="mb-3">

    <div class="input-group">
        <input type="text"
               name="search"
               value="@Context.Request.Query["search"]"
               class="form-control"
               placeholder="Ara (marka, model, plaka)">

        <button class="btn btn-primary" type="submit">
            🔍 Ara
        </button>
    </div>

</form>

<div class="d-flex justify-content-end mb-3">
    <button class="btn btn-dark"
            data-bs-toggle="offcanvas"
            data-bs-target="#filterSidebar">
        🔍 Filtrele
    </button>
</div>
    <hr>
<div class="offcanvas offcanvas-end" tabindex="-1" id="filterSidebar" style="width:320px;">
    <!-- HEADER -->
    <div class="offcanvas-header">
        <h5 class="offcanvas-title fw-bold text-primary">
            🔍 Filtrele
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <!-- BODY -->
    <div class="offcanvas-body">
        <form method="get" action="/Car/UserList">

            <!-- MARKA -->
            <div class="mb-3">
                <label>Marka</label>
                <input type="text" name="Brand" class="form-control">
            </div>
           
            <!-- MODEL -->
            <div class="mb-3">
                <label>Model</label>
                <input type="text" name="ModelName" class="form-control">
            </div>

            <!-- YIL -->
            <div class="mb-3">
                <label>Model Yılı</label>
                <div class="d-flex gap-2">
                    <input type="number" name="MinYear" class="form-control" placeholder="Min">
                    <input type="number" name="MaxYear" class="form-control" placeholder="Max">
                </div>
            </div>

            <!-- VİTES -->
            <div class="mb-3">
                <label>Vites</label>
                <select name="Transmission" class="form-control">
                    <option value="">Hepsi</option>
                    <option value="0">Manuel</option>
                    <option value="1">Otomatik</option>
                </select>
            </div>

            <!-- YAKIT -->
            <div class="mb-3">
                <label>Yakıt</label>
                <select name="FuelType" class="form-control">
                    <option value="">Hepsi</option>
                    <option value="0">Benzin</option>
                    <option value="1">Dizel</option>
                    <option value="2">Elektrik</option>
                </select>
            </div>

            <!-- ŞOFÖR -->
            <div class="mb-3">
                <label>Şoför</label>
                <select name="IsChauffeured" class="form-control">
                    <option value="">Hepsi</option>
                    <option value="true">Var</option>
                    <option value="false">Yok</option>
                </select>
            </div>

                        <!-- FİYAT TİPİ -->
            <div class="mb-3">
                <label>Fiyat Türü</label>
                <select name="PriceType" class="form-control">
                    <option value="daily">Günlük</option>
                    <option value="weekly">Haftalık</option>
                    <option value="monthly">Aylık</option>
                </select>
            </div>

            <!-- FİYAT ARALIĞI -->
            <div class="mb-3">
                <label>Fiyat Aralığı</label>
                <div class="d-flex gap-2">
                    <input type="number" name="MinPrice" class="form-control" placeholder="Min ₺">
                    <input type="number" name="MaxPrice" class="form-control" placeholder="Max ₺">
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Filtrele
            </button>

        </form>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="text-center mt-5">
        <h4 class="text-danger">Filtreye uygun araç bulunamadı</h4>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var car in Model)
        {
            <!-- kart -->
        }
    </div>
}
@* @if (Context.Request.Query.Any())
{
    <div class="mb-3">
        <span class="badge bg-primary">Filtre aktif</span>
    </div>
} *@

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var car in Model)
            {
                <div class="col">
                    @* 🚩 position-relative ve car-card-wrapper: Tüm kartın tıklanabilir olmasını sağlar *@
                    <div class="card h-100 border-0 shadow-sm car-card overflow-hidden position-relative h-100 shadow-hover">
                        <a href="/Rental/Create?carId=@car.Id" class="stretched-link"></a>
                        @* Araç Resmi (Müsait yazısı kaldırıldı) *@
                        <div class="img-container">
                            <img src="@(string.IsNullOrEmpty(car.ImagePath) ? "/images/default-car.png" : car.ImagePath)"
                                 class="card-img-top" alt="@car.Brand" style="height: 230px; object-fit: cover;">
                        </div>

                        <div class="card-body p-4 d-flex flex-column">
                            <h5 class="card-title fw-bold text-uppercase mb-3">@car.Brand @car.ModelName</h5>
                            
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2"><i
                                    class="bi bi-card-text"></i> @car.Plate</span>
                                    <span class="badge bg-light text-dark border rounded-pill px-3 py-2"><i
                                        class="bi bi-calendar3"></i> @car.ModelYear</span>
                                        <span class="badge bg-light text-dark border rounded-pill px-3 py-2"><i
                                            class="bi bi-geo-alt"></i> @car.Location</span>
                                        </div>

                                        <p class="card-text text-muted small mb-4">@car.Description</p>
                            
                                        @* <div class="mt-auto pt-3 border-top">
                                             🚩 stretched-link class'ı sayesinde resim dahil tüm kart bu linke dönüşür 
                                            <a href="/Rental/Create?carId=@car.Id"
                                                   class="btn btn-primary w-100 fw-bold py-2 rounded-pill stretched-link">
                                                <i class="bi bi-info-circle"></i>
                                            </a> 
                                        </div> *@
                                    </div>
                                </div>
                            </div>
                        }
                    }
        else
                    {
                        <div class="col-12 text-center py-5">
                            <i class="bi bi-car-front display-1 text-light-emphasis"></i>
                            <h4 class="mt-3 text-secondary">Şu an listelenecek araç bulunamadı.</h4>
                        </div>
                    }
                </div>
            </div>

            <style>
                /* Kartın her yerinin tıklanabilir olduğunu hissettiren stil */
                .car-card {
                    transition: all 0.3s ease-in-out;
                    cursor: pointer;
                    /* Fare gelince el işareti çıkar */
                }

                .car-card:hover {
                    transform: translateY(-10px);
                    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12) !important;
                }

                /* Resme hover efekti */
                .img-container {
                    overflow: hidden;
                }

                .car-card:hover .card-img-top {
                    transform: scale(1.05);
                    transition: transform 0.5s ease;
                }

                .btn-primary {
                    background: #0d6efd;
                    border: none;
                    z-index: 2;
                    /* Butonun tıklanma önceliğini korur */
                }

                /* Yazıların çok fazla alanı kaplayıp kartları asimetrik yapmasını engeller */
                .card-text {
                    display: -webkit-box;
                    -webkit-line-clamp: 2;
                    -webkit-box-orient: vertical;
                    overflow: hidden;
                }
            </style>
            <script>
    function toggleFilter() {
        var box = document.getElementById("filterBox");

        if (box.style.display === "none") {
            box.style.display = "block";
        } else {
            box.style.display = "none";
        }
    }

    // 🔥 CANLI ARAMA BURASI
    document.getElementById("searchBox").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();

        document.querySelectorAll(".card").forEach(card => {
            card.style.display =
                card.innerText.toLowerCase().includes(value)
                ? ""
                : "none";
        });
    });
</script>
