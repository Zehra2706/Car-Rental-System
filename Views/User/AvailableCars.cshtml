@model List<car.Models.Car>
@{
    Layout = "_Layout";
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Değerli Üyemiz");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 80px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.08);
        z-index: 2000;
    }

    .topbar-left-btn {
        font-size: 30px;
        cursor: pointer;
        color: #1e3a8a;
        user-select: none;
    }

    .topbar-right-area {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .user-name-tag {
        font-weight: 600;
        color: #334155;
    }

    .logout-btn-new {
        background: #ef4444;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
    }

    /* SIDEBAR */
    .sidebar {
        position: fixed;
        left: -280px;
        top: 0;
        width: 280px;
        height: 100%;
        background: #1e3a8a;
        color: white;
        padding: 25px;
        transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 3000;
    }

    .sidebar.active {
        left: 0;
    }

    .sidebar a {
        display: block;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        padding: 12px 15px;
        margin: 10px 0;
        border-radius: 10px;
    }

    .sidebar a:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }

    /* KART STİLLERİ */
    .car-card {
        transition: all 0.3s ease-in-out;
        border-radius: 20px;
        overflow: hidden;
    }

    .car-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1) !important;
    }

    .img-container {
        height: 200px;
        overflow: hidden;
    }

    .card-img-top {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .car-card:hover .card-img-top {
        transform: scale(1.1);
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>

    <div class="topbar-right-area">
        <span class="user-name-tag d-none d-md-inline">
            <i class="bi bi-person-circle me-1 text-primary"></i> @displayDisplayName
        </span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/User/Index"><i class="bi bi-house-door me-2"></i> Dashboard</a>
    <a href="/User/AvailableCars"><i class="bi bi-car-front me-2"></i> Araç Kirala</a>
    <a href="/User/MyRentals"><i class="bi bi-list-check me-2"></i> Kiralamalarım</a>
    <hr class="opacity-25">
    <a href="/User/IncomingRequests?filter=aktif"><i class="bi bi-bell-fill me-2 text-warning"></i> Talepleri Yönet</a>
    <a href="/Car/MyCars"><i class="bi bi-tags me-2"></i> İlanlarım</a>
    <a href="/Car/Create"><i class="bi bi-plus-square me-2"></i> Araç Ekle</a>
    <a href="/User/EditProfile"><i class="bi bi-gear me-2"></i> Ayarlar</a>
</div>

<div class="container">
    <div class="mb-4 d-flex justify-content-between align-items-center">

        <div>
            <h2 class="fw-bold text-dark mb-1">
                🚗 <span class="text-primary">Araç Filomuz</span>
            </h2>
            <p class="text-muted mb-0">Senin için en uygun aracı hemen bul.</p>
        </div>

        <a href="javascript:history.back()" class="btn btn-outline-dark rounded-pill px-3 shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Geri Dön
        </a>

    </div>

    <div class="row mb-4 align-items-center">
        <div class="col-md-auto mb-3 mb-md-0">
            <button class="btn btn-dark rounded-pill px-4 shadow-sm" data-bs-toggle="offcanvas"
                    data-bs-target="#filterSidebar">
                <i class="bi bi-funnel-fill me-2"></i>Filtrele
            </button>
        </div>
        <div class="col-md">
            <form method="get" action="/Car/UserList">
            @Html.AntiForgeryToken()
                <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                    <input type="text" id="searchBox" name="search" value="@Context.Request.Query["search"]"
                           class="form-control border-0 px-4" placeholder="Marka, model, plaka vb. ile ara...">
                    <button class="btn btn-primary px-4" type="submit">🔍 Ara</button>
                </div>
            </form>
        </div>
    </div>

    <hr class="opacity-25 mb-5">

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var car in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm car-card position-relative shadow-hover bg-white">
                        <a href="/Rental/Create?carId=@car.Id" class="stretched-link"></a>
                        
                        <div class="img-container">
                            <img src="@(string.IsNullOrEmpty(car.ImagePath) ? "/images/default-car.png" : car.ImagePath)"
                                 class="card-img-top" alt="@car.Brand">
                        </div>

                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold text-uppercase mb-3">@car.Brand @car.ModelName</h5>
                            
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2 small">
                                    <i class="bi bi-calendar3"></i> @car.ModelYear
                                </span>
                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2 small">
                                    <i class="bi bi-geo-alt"></i> @car.Location
                                </span>
                            </div>

                            <p class="card-text text-muted small"
                                   style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @car.Description
                            </p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-search display-1 text-muted opacity-25"></i>
                <h4 class="mt-3 text-secondary">Uygun araç bulunamadı.</h4>
            </div>
        }
    </div>
</div>

<div class="offcanvas offcanvas-start" tabindex="-1" id="filterSidebar" style="width:320px;">
    <div class="offcanvas-header bg-primary text-white">
        <h5 class="offcanvas-title fw-bold">🔍 Detaylı Filtre</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
    
        <form method="get" action="/Car/UserList">
        @Html.AntiForgeryToken()

            <!-- MARKA -->
            <div class="mb-3">
                <label>Marka</label>
                <input type="text" name="Brand" class="form-control">
            </div>
           
            <!-- MODEL -->
            <div class="mb-3">
                <label>Model</label>
                <input type="text" name="ModelName" class="form-control">
            </div>

            <!-- YIL -->
            <div class="mb-3">
                <label>Model Yılı</label>
                <div class="d-flex gap-2">
                    <input type="number" name="MinYear" class="form-control" placeholder="Min">
                    <input type="number" name="MaxYear" class="form-control" placeholder="Max">
                </div>
            </div>

            <!-- VİTES -->
            <div class="mb-3">
                <label>Vites</label>
                <select name="Transmission" class="form-control">
                    <option value="">Hepsi</option>
                    <option value="0">Manuel</option>
                    <option value="1">Otomatik</option>
                </select>
            </div>

            <!-- YAKIT -->
            <div class="mb-3">
                <label>Yakıt</label>
                <select name="FuelType" class="form-control">
                    <option value="">Hepsi</option>
                    <option value="0">Benzin</option>
                    <option value="1">Dizel</option>
                    <option value="2">Elektrik</option>
                    <option value="3">Hibrit</option>
                </select>
            </div>

            <!-- ŞOFÖR -->
            <div class="mb-3">
                <label>Şoför</label>
                <select name="IsChauffeured" class="form-control">
                    <option value="">Hepsi</option>
                    <option value="true">Var</option>
                    <option value="false">Yok</option>
                </select>
            </div>

            <!-- FİYAT TİPİ -->
            <div class="mb-3">
                <label>Fiyat Türü</label>
                <select name="PriceType" class="form-control">
                    <option value="daily">Günlük</option>
                    <option value="weekly">Haftalık</option>
                    <option value="monthly">Aylık</option>
                </select>
            </div>

            <!-- FİYAT ARALIĞI -->
            <div class="mb-3">
                <label>Fiyat Aralığı</label>
                <div class="d-flex gap-2">
                    <input type="number" name="MinPrice" class="form-control" placeholder="Min ₺">
                    <input type="number" name="MaxPrice" class="form-control" placeholder="Max ₺">
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Filtrele
            </button>

        </form>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }

    // Canlı Arama JS (Kartları anlık gizler)
    document.getElementById("searchBox").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        document.querySelectorAll(".col").forEach(col => {
            if (col.querySelector(".card")) {
                col.style.display = col.innerText.toLowerCase().includes(value) ? "" : "none";
            }
        });
    });
</script>