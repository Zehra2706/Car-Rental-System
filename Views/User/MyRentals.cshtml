@model List<rental.Models.Rental>
@{
    Layout = "_Layout";
    // URL'deki filtreyi kontrol ediyoruz
    bool isAktifMod = Context.Request.Query["filter"] == "aktif";
    var sayfaBasligi = isAktifMod ? "Aktif Kiralamalarım ve Taleplerim" : "Tüm Kiralama Geçmişim";

    // Kullanıcı adını diğer sayfalarla aynı mantıkta çekiyoruz
    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    string displayDisplayName = !string.IsNullOrEmpty(userNameFromSession) ? userNameFromSession :
                               (!string.IsNullOrEmpty(userEmail) ? userEmail.Split('@')[0] : "Değerli Üyemiz");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 80px;
    }

    /* TOPBAR */
    .custom-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        z-index: 2000;
    }

    .topbar-left-btn { font-size: 30px; cursor: pointer; color: #1e3a8a; }
    .topbar-right-area { display: flex; align-items: center; gap: 20px; }
    .logout-btn-new {
        background: #ef4444; color: white; border: none;
        padding: 8px 16px; border-radius: 10px; font-weight: 600; text-decoration: none;
    }

    /* SIDEBAR */
    .sidebar {
        position: fixed; left: -280px; top: 0; width: 280px; height: 100%;
        background: #1e3a8a; color: white; padding: 25px;
        transition: 0.4s; z-index: 3000;
    }
    .sidebar.active { left: 0; }
    .sidebar a { display: block; color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px; margin: 8px 0; border-radius: 10px; }
    .sidebar a:hover { background: rgba(255,255,255,0.15); color: white; }

    /* TABLE STYLES */
    .table-card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background: #f8fafc;
        border-bottom: 2px solid #edf2f7;
    }
</style>

<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>
    <div class="topbar-right-area">
        <span class="fw-bold text-dark d-none d-md-inline">
            <i class="bi bi-person-circle me-1 text-primary"></i> @displayDisplayName
        </span>
    </div>
</div>

<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>
    <a href="/User/Index"><i class="bi bi-house-door me-2"></i> Dashboard</a>
    <a href="/User/AvailableCars"><i class="bi bi-car-front me-2"></i> Araç Kirala</a>
    <a href="/User/MyRentals"><i class="bi bi-list-check me-2"></i> Kiralamalarım</a>
    <hr class="opacity-25">
    <a href="/User/IncomingRequests?filter=aktif"><i class="bi bi-bell-fill me-2 text-warning"></i> Talepleri Yönet</a>
    <a href="/Car/MyCars"><i class="bi bi-tags me-2"></i> İlanlarım</a>
    <a href="/Car/Create"><i class="bi bi-plus-square me-2"></i> Araç Ekle</a>
    <a href="/User/EditProfile"><i class="bi bi-gear me-2"></i> Ayarlar</a>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="bi bi-clock-history text-warning"></i> @sayfaBasligi</h2>
            <p class="text-muted small">Tüm kiralama süreçlerini buradan takip edebilirsin.</p>
        </div>
        <a href="/User/Index" class="btn btn-white shadow-sm rounded-pill border-0 px-4">
            <i class="bi bi-arrow-left"></i> Geri Dön
        </a>
    </div>

    <div class="table-card card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4 py-3">Araç</th>
                            <th class="py-3">Başlangıç</th>
                            <th class="py-3">Bitiş</th>
                            <th class="py-3">Öngörülen Tutar</th>
                            <th class="py-3">Durum</th>
                            @if (isAktifMod)
                            {
                                <th class="text-center py-3">İşlem</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var currentStatus = item.Status?.Trim() ?? "";

                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark">@item.Car?.Brand @item.Car?.ModelName</div>
                                        <span class="badge bg-secondary-subtle text-secondary fw-normal">@item.Car?.Plate</span>
                                    </td>
                                    <td><i class="bi bi-calendar-event me-1"></i> @item.Date.ToShortDateString()</td>
                                    <td><i class="bi bi-calendar-check me-1"></i> @item.ReturnDate.ToShortDateString()</td>
                                    <td class="fw-bold text-primary">@item.Forecast.ToString("C2")</td>
                                    <td>
                                        @if (currentStatus == "OnayBekliyor")
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">Onay Bekliyor</span>
                                        }
                                        else if (currentStatus == "Onaylandı" && !item.IsReturned)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">Kullanımda (Aktif)</span>
                                        }
                                        else if (item.IsReturned || currentStatus == "İade Edildi" || currentStatus == "Tamamlandı")
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">İade Edildi</span>
                                        }
                                        else if (currentStatus == "Reddedildi")
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">Reddedildi</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark px-3 py-2 border">@currentStatus</span>
                                        }
                                    </td>
                                    
                                    @if (isAktifMod)
                                    {
                                        <td class="text-center">
                                            @if (currentStatus == "Onaylandı" || currentStatus == "Gecikmiş" || currentStatus == "Gecikmis" || (currentStatus == "Onaylandi" && !item.IsReturned))
                                            {
                                             <a href="/Rental/ReturnPaymentConfirm?rentalId=@item.Id"
   class="btn btn-sm btn-success rounded-pill px-3 shadow-sm border-0">
    <i class="bi bi-box-arrow-in-left"></i> İade Et ve Öde
</a>
                                            }
                                            else if (currentStatus == "OnayBekliyor")
                                            {
                                                <form asp-action="CancelRequest" asp-controller="Rental" method="post" style="display:inline;">
                                                    <input type="hidden" name="rentalId" value="@item.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-warning rounded-pill px-3 shadow-sm"
                                                            onclick="return confirm('Bu talebi geri çekmek istediğinize emin misiniz?')">
                                                        <i class="bi bi-x-circle"></i> İsteği Geri Al
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(isAktifMod ? 6 : 5)" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-inbox display-4 d-block mb-3 opacity-25"></i>
                                        Henüz listelenecek bir kayıt bulunmuyor.
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }
</script>