@model List<rental.Models.Rental>
@{
    Layout = "_Layout";
    var sayfaBasligi = ViewBag.PageTitle ?? "Kiralama Taleplerim";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-clock-history text-warning"></i> @sayfaBasligi</h2>
        <a href="/User/Index" class="btn btn-outline-secondary btn-sm">Panele Dön</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Araç</th>
                        <th>Başlangıç</th>
                        <th>Bitiş</th>
                        <th>Öngörülen Tutar</th>
                        <th>Durum</th>
                        <th class="text-center">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            // Status değerini güvenli bir değişkene alalım
                            var currentStatus = item.Status?.Trim() ?? "";

                            <tr>
                                <td class="ps-4">
                                    <strong>@item.Car?.Brand @item.Car?.ModelName</strong><br>
                                    <small class="text-muted">@item.Car?.Plate</small>
                                </td>
                                <td>@item.Date.ToShortDateString()</td>
                                <td>@item.ReturnDate.ToShortDateString()</td>
                                <td class="fw-bold text-primary">@item.Forecast.ToString("C2")</td>
                                <td>
                                    @* DURUM KONTROLLERİ *@
                                    @if (currentStatus == "OnayBekliyor")
                                    {
                                        <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                                    }
                                    @* İçinde "Onay" kelimesi geçiyorsa ve iade edilmemişse *@
                                    else if (currentStatus.Contains("Onay") && !item.IsReturned)
                                    {
                                        <span class="badge bg-success">Kullanımda (Onaylandı)</span>
                                    }
                                    else if (item.IsReturned || currentStatus == "Tamamlandı")
                                    {
                                        <span class="badge bg-secondary">İade Edildi</span>
                                    }
                                    else if (currentStatus == "Reddedildi")
                                    {
                                        <span class="badge bg-danger">Reddedildi</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark">@currentStatus</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @* İŞLEM BUTONU KONTROLÜ *@
                                    @if (currentStatus.Contains("Onay") && !item.IsReturned)
                                    {
                                        <form asp-action="ProcessReturnPayment" asp-controller="Rental" method="post">
                                            <input type="hidden" name="rentalId" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-success shadow-sm">
                                                <i class="bi bi-box-arrow-in-left"></i> İade Et ve Öde
                                            </button>
                                        </form>
                                    }
                                    else if (item.IsReturned)
                                    {
                                        <small class="text-success fw-bold">İşlem Kapandı</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                Henüz bir kiralama talebiniz bulunmuyor.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>