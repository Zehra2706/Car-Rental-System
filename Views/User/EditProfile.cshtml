@model car.ViewModels.EditProfileViewModel

@{
    Layout = "_Layout";

    var userNameFromSession = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");

    string displayDisplayName =
        !string.IsNullOrEmpty(userNameFromSession)
        ? userNameFromSession
        : (!string.IsNullOrEmpty(userEmail)
            ? userEmail.Split('@')[0]
            : "Değerli Üyemiz");
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f7fa;
        padding-top: 90px;
    }

    .custom-topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 30px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.08);
        z-index: 2000;
    }

    .topbar-left-btn {
        font-size: 30px;
        cursor: pointer;
        color: #1e3a8a;
    }

    .sidebar {
        position: fixed;
        left: -280px;
        top: 0;
        width: 280px;
        height: 100%;
        background: #1e3a8a;
        color: white;
        padding: 25px;
        transition: 0.4s;
        z-index: 3000;
    }

    .sidebar.active {
        left: 0;
    }

    .sidebar a {
        display: block;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        padding: 12px;
        margin: 8px 0;
        border-radius: 10px;
    }

    .sidebar a:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }

    .profile-card {
        border: none;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }
</style>

<!-- TOPBAR -->
<div class="custom-topbar">
    <div class="topbar-left-btn" onclick="toggleMenu()">
        <i class="bi bi-list"></i>
    </div>

    <div class="topbar-right-area">
        <span class="fw-bold text-dark d-none d-md-inline">
            <i class="bi bi-person-circle me-1 text-primary"></i> @displayDisplayName
        </span>
    </div>
</div>

<!-- SIDEBAR -->
<div id="sidebar" class="sidebar shadow-lg">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Menü</h3>
        <i class="bi bi-x-lg" style="cursor:pointer" onclick="toggleMenu()"></i>
    </div>

    <a href="/User/Index">Ana Sayfa</a>
    <a href="/User/AvailableCars">Araç Kirala</a>
    <a href="/User/MyRentals">Kiralamalarım</a>
    <a href="/Car/MyCars">İlanlarım</a>
    <a href="/Car/Create">Araç Ekle</a>
    <a href="/User/EditProfile">Ayarlar</a>
</div>

<!-- CONTENT -->
<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-dark m-0">
                    <i class="bi bi-person-vcard text-primary"></i> Profil Ayarlarım
                </h2>

                <a href="/User/Index" class="btn btn-outline-dark rounded-pill px-4">
                    <i class="bi bi-arrow-left"></i> Vazgeç
                </a>
            </div>

            <div class="profile-card p-4 p-md-5">

                <form action="/User/EditProfile" method="post">
                    @Html.AntiForgeryToken()

                    <!-- AD SOYAD -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">AD</label>
                            <input type="text" name="Name" class="form-control" value="@Model?.Name" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">SOYAD</label>
                            <input type="text" name="Surname" class="form-control" value="@Model?.Surname" required />
                        </div>
                    </div>

                    <!-- EMAIL -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary">E-POSTA</label>
                        <input type="email" class="form-control bg-light"
                               value="@Context.Session.GetString("UserEmail")" readonly />
                    </div>

                    <!-- TC -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary">TC</label>
                        <input type="text" class="form-control bg-light" value="@Context.Session.GetString("TC")"
                               readonly />
                    </div>

                    <!-- EHLİYET -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary">EHLİYET NUMARASI</label>
                        <input type="text" class="form-control bg-light" value="@Context.Session.GetString("LicenceNo")"
                               readonly />
                    </div>

                    <!-- TELEFON -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary">TELEFON</label>
                        <input type="tel" name="PhoneNumber" class="form-control" value="@Model?.PhoneNumber"
                               required />
                    </div>

                    <!-- ADRES -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary">ADRES</label>
                        <textarea name="Address" class="form-control" rows="3" required>@Model?.Address</textarea>
                    </div>

                    <!-- KAYDET -->
                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-3">
                        <i class="bi bi-check-circle me-2"></i> Kaydet
                    </button>

                </form>

                <!-- HESAP SİL -->
                <form method="post" action="/User/DeleteAccount" onsubmit="return confirmDelete()"
                      class="mt-4 text-center">

                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        Hesabımı Sil
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

<script>
    function toggleMenu() {
        document.getElementById("sidebar").classList.toggle("active");
    }

    function confirmDelete() {
        return confirm("Hesabınızı silmek istediğinize emin misiniz? Bu işlem geri alınamaz!");
    }
</script>