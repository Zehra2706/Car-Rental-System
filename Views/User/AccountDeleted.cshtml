@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Hesap Silindi</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background: #f4f7fa;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: Arial;
        }

        .box {
            text-align: center;
            background: white;
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .icon {
            font-size: 60px;
            color: #28a745;
        }

        .btn {
            margin-top: 20px;
        }
    </style>
</head>

<body>

<div class="box">
    <div class="icon">✔</div>

    <h2 class="mt-3">Hesabın Silindi</h2>

    <p class="text-muted">
        Hesabınız başarıyla silindi. Artık sistemde kayıtlı değilsiniz.
    </p>

    <a href="/Auth/Login" class="btn btn-primary px-4">
        Giriş Sayfasına Git
    </a>
</div>

</body>
</html>